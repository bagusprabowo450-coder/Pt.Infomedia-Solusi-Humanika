function openGiveBadgeModal(badgeName,badgeIcon){
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">🎁 Berikan Badge</h3>
    <div style="background:rgba(0,212,255,0.08);padding:12px;border-radius:10px;margin-bottom:16px;text-align:center">
