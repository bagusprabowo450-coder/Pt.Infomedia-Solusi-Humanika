    </div>
  `);
}

async function giveBadge(badgeName,badgeIcon){
  const empId=document.getElementById('badgeEmp').value;
  if(!empId){showToast('Pilih karyawan terlebih dahulu','error');return}
  const btn=document.getElementById('giveBadgeBtn');btn.disabled=true;btn.textContent='Memberikan...';
  const result=await window.dataSdk.create({
    type:'badge',
    employee_id:empId,
    badge_name:badgeName,
    badge_icon:badgeIcon,
    badge_criteria:'',
    employee_badges:'',
    badge_date:new Date().toISOString(),
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',overtime_hours:0,overtime_date:'',overtime_reason:'',skill_name:'',skill_level:0,skill_category:'',note_title:'',note_content:'',note_date:'',note_priority:'',note_status:'',project_name:'',project_desc:'',project_status:'',project_lead:'',project_deadline:'',team_members:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('🎁 Badge berhasil diberikan!');closeModal();}
  else{showToast('Gagal memberikan badge','error');btn.disabled=false;btn.textContent='Berikan';}
}

// ========== SKILLS MANAGEMENT ==========
function renderSkillsAdmin(el){
  const allSkills=allRecords.filter(r=>r.type==='skill');
  const uniqueSkills=new Map();
  allSkills.forEach(s=>{
    const key=s.skill_name;
    if(!uniqueSkills.has(key)||s.skill_level>(uniqueSkills.get(key).skill_level||0)){
      uniqueSkills.set(key,s);
    }
  });
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">⚡ Skill Management</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('🎓','Total Skills',uniqueSkills.size,'skills','#7c3aed')}
    ${statCard('👥','Karyawan Terlatih',new Set(allSkills.map(s=>s.employee_id)).size,'orang','#00d4ff')}
  </div>
  <div style="display:grid;gap:12px">
  ${Array.from(uniqueSkills.values()).length?Array.from(uniqueSkills.values()).map(s=>{
    const holders=allSkills.filter(sk=>sk.skill_name===s.skill_name);
    const avgLevel=(holders.reduce((sum,h)=>sum+(h.skill_level||0),0)/holders.length).toFixed(1);
    return`<div class="card" style="padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1">
          <div style="font-size:15px;font-weight:700">${s.skill_name}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">Kategori: ${s.skill_category||'General'}</div>
          <div style="margin-top:8px;display:flex;align-items:center;gap:8px">
            <div class="progress-bar" style="flex:1"><div class="progress-fill" style="width:${avgLevel*20}%;max-width:100px"></div></div>
            <span style="font-size:12px;font-weight:700;color:var(--accent)">${avgLevel}/5</span>
          </div>
          <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:4px">${holders.length} karyawan memiliki skill ini</div>
        </div>
      </div>
    </div>`;
  }).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada skill tercatat</p></div>'}
  </div></div>`;
}

function renderMySkills(el){
  const emp=currentUser.emp;
  const mySkills=getEmpRecords(emp.id).filter(r=>r.type==='skill').sort((a,b)=>b.skill_level-a.skill_level);
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">⚡ Skill Saya</h1>
    <button class="btn-primary" onclick="openAddSkillModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Tambah Skill</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:20px">
    ${statCard('🎓','Total',mySkills.length,'skills','#7c3aed')}
  </div>
  <div style="display:grid;gap:12px">
  ${mySkills.length?mySkills.map(s=>`<div class="card" style="padding:14px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${s.skill_name}</div>
        <div style="font-size:11px;color:rgba(226,232,240,0.4)">${s.skill_category||'General'}</div>
        <div style="margin-top:8px;display:flex;align-items:center;gap:8px">
          <div class="progress-bar" style="flex:1"><div class="progress-fill" style="width:${s.skill_level*20}%;max-width:80px"></div></div>
          <span style="font-size:12px;font-weight:700;color:#fbbf24">${s.skill_level}/5</span>
        </div>
      </div>
      <button class="btn-secondary" style="font-size:11px;padding:4px 10px;color:#ef4444;border-color:rgba(239,68,68,0.3)" onclick="confirmDelete('${s.__backendId}',this)">🗑</button>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:40px"><p style="color:rgba(226,232,240,0.3)">Belum ada skill. Tambahkan skill yang Anda kuasai.</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddSkillModal(){
  if(allRecords.filter(r=>r.employee_id===currentUser.emp.id).length>=999){showToast('Batas data tercapai','error');return}
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">⚡ Tambah Skill</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Nama Skill</label><input id="skillName" class="input-field" placeholder="Contoh: JavaScript"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Kategori</label><select id="skillCat" class="input-field"><option value="Technical">Technical</option><option value="Soft Skills">Soft Skills</option><option value="Language">Language</option><option value="Tools">Tools</option><option value="Other">Other</option></select></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Level (1-5)</label><input id="skillLevel" class="input-field" type="range" min="1" max="5" value="3" style="width:100%;cursor:pointer"></div>
      <div style="display:flex;justify-content:space-between;padding:8px;background:rgba(0,212,255,0.08);border-radius:8px;font-size:12px">
        <span style="color:rgba(226,232,240,0.5)">Pemula</span>
        <span style="color:var(--accent);font-weight:700" id="skillLevelDisplay">3/5</span>
        <span style="color:rgba(226,232,240,0.5)">Expert</span>
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveSkillBtn" onclick="saveSkill()">Simpan</button>
    </div>
  `);
  document.getElementById('skillLevel').addEventListener('input',function(){
    document.getElementById('skillLevelDisplay').textContent=this.value+'/5';
  });
}

async function saveSkill(){
  const name=document.getElementById('skillName').value.trim();
  if(!name){showToast('Nama skill harus diisi','error');return}
  const btn=document.getElementById('saveSkillBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'skill',
    employee_id:currentUser.emp.id,
    skill_name:name,
    skill_level:parseInt(document.getElementById('skillLevel').value),
    skill_category:document.getElementById('skillCat').value,
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',note_title:'',note_content:'',note_date:'',note_priority:'',note_status:'',project_name:'',project_desc:'',project_status:'',project_lead:'',project_deadline:'',team_members:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Skill berhasil ditambahkan');closeModal();}
  else{showToast('Gagal menyimpan skill','error');btn.disabled=false;btn.textContent='Simpan';}
}

// ========== NOTES & REMINDERS ==========
function renderNotesAdmin(el){
  const notes=allRecords.filter(r=>r.type==='note').sort((a,b)=>new Date(b.note_date)-new Date(a.note_date));
  const urgent=notes.filter(r=>r.note_priority==='Urgent').length;
  const normal=notes.filter(r=>r.note_priority==='Normal').length;
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">📝 Team Notes</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📝','Total',notes.length,'notes','#00d4ff')}
    ${statCard('🔴','Urgent',urgent,'items','#ef4444')}
    ${statCard('⚪','Normal',normal,'items','#fbbf24')}
  </div>
  <div style="display:grid;gap:12px">
  ${notes.length?notes.map(n=>`<div class="card" style="padding:14px;border-left:3px solid ${n.note_priority==='Urgent'?'#ef4444':'#fbbf24'}">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${n.note_title}</div>
        <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:2px">${getEmp(n.employee_id)?.name||n.employee_id} • ${formatDate(n.note_date)}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:6px">${n.note_content.substring(0,100)}${n.note_content.length>100?'...':''}</div>
      </div>
      <span class="badge ${n.note_priority==='Urgent'?'status-pending':'status-progress'}">${n.note_priority}</span>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada notes</p></div>'}
  </div></div>`;
}

function renderMyNotes(el){
  const notes=getEmpRecords(currentUser.emp.id).filter(r=>r.type==='note').sort((a,b)=>new Date(b.note_date)-new Date(a.note_date));
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📝 Note Saya</h1>
    <button class="btn-primary" onclick="openAddNoteModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Tambah Note</button>
  </div>
  <div style="display:grid;gap:12px">
  ${notes.length?notes.map(n=>`<div class="card" style="padding:14px;border-left:3px solid ${n.note_priority==='Urgent'?'#ef4444':'#fbbf24'}">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${n.note_title}</div>
        <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:2px">${formatDate(n.note_date)}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:6px;white-space:pre-wrap">${n.note_content}</div>
      </div>
      <div style="display:flex;gap:4px">
        <span class="badge ${n.note_priority==='Urgent'?'status-pending':'status-progress'}">${n.note_priority}</span>
        <button class="btn-secondary" style="font-size:11px;padding:4px 10px;color:#ef4444;border-color:rgba(239,68,68,0.3)" onclick="confirmDelete('${n.__backendId}',this)">🗑</button>
      </div>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:40px"><p style="color:rgba(226,232,240,0.3)">Belum ada notes pribadi</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddNoteModal(){
  if(allRecords.filter(r=>r.employee_id===currentUser.emp.id).length>=999){showToast('Batas data tercapai','error');return}
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📝 Tambah Note</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Judul</label><input id="noteTitle" class="input-field" placeholder="Judul note..."></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Konten</label><textarea id="noteContent" class="input-field" rows="4" placeholder="Tulis catatan..."></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Prioritas</label><select id="notePriority" class="input-field"><option value="Normal">Normal</option><option value="Urgent">Urgent 🔴</option></select></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal</label><input id="noteDate" class="input-field" type="date"></div>
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveNoteBtn" onclick="saveNote()">Simpan</button>
    </div>
  `);
  document.getElementById('noteDate').value=new Date().toISOString().split('T')[0];
}

async function saveNote(){
  const title=document.getElementById('noteTitle').value.trim();
  if(!title){showToast('Judul note harus diisi','error');return}
  const btn=document.getElementById('saveNoteBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'note',
    employee_id:currentUser.emp.id,
    note_title:title,
    note_content:document.getElementById('noteContent').value.trim(),
    note_date:document.getElementById('noteDate').value,
    note_priority:document.getElementById('notePriority').value,
    note_status:'Active',
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',skill_name:'',skill_level:0,skill_category:'',project_name:'',project_desc:'',project_status:'',project_lead:'',project_deadline:'',team_members:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Note berhasil disimpan');closeModal();}
  else{showToast('Gagal menyimpan note','error');btn.disabled=false;btn.textContent='Simpan';}
}

// ========== PROJECT MANAGEMENT ==========
function renderProjectsAdmin(el){
  const projects=allRecords.filter(r=>r.type==='project').sort((a,b)=>new Date(b.project_deadline)-new Date(a.project_deadline));
  const active=projects.filter(r=>r.project_status==='In Progress').length;
  const completed=projects.filter(r=>r.project_status==='Completed').length;
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">📊 Project Management</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📊','Total',projects.length,'projects','#a78bfa')}
    ${statCard('⏳','Active',active,'berjalan','#fbbf24')}
    ${statCard('✅','Completed',completed,'selesai','#10b981')}
  </div>
  <div style="display:grid;gap:12px">
  ${projects.length?projects.map(p=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1;min-width:200px">
        <div style="font-size:15px;font-weight:700">${p.project_name}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">Lead: ${p.project_lead} • Deadline: ${formatDate(p.project_deadline)}</div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${p.project_desc}</div>
        ${p.team_members?`<div style="font-size:11px;color:rgba(226,232,240,0.5);margin-top:6px">👥 Tim: ${p.team_members}</div>`:''}
      </div>
      <span class="badge ${p.project_status==='Completed'?'status-done':p.project_status==='In Progress'?'status-progress':'status-pending'}">${p.project_status}</span>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada project</p></div>'}
  </div></div>`;
}

// ========== EVENTS & ATTENDANCE ==========
function renderEventsAdmin(el){
  const events=allRecords.filter(r=>r.type==='event').sort((a,b)=>new Date(b.event_date)-new Date(a.event_date));
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📅 Event & Attendance</h1>
    <button class="btn-primary" onclick="openAddEventModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Buat Event</button>
  </div>
  <div style="display:grid;gap:12px">
  ${events.length?events.map(e=>{
    const attended=allRecords.filter(r=>r.type==='attendance'&&r.event_title===e.event_title&&r.attendance==='Present').length;
    return`<div class="card" style="padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1">
          <div style="font-size:15px;font-weight:700">${e.event_title}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">📅 ${formatDate(e.event_date)} • 🕐 ${e.event_time||'-'} • 📍 ${e.event_location||'-'}</div>
          <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${e.event_description}</div>
          <div style="font-size:11px;color:rgba(226,232,240,0.5);margin-top:6px">✅ Hadir: ${attended}/${EMPLOYEES.length}</div>
        </div>
      </div>
    </div>`;
  }).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada event</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddEventModal(){
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📅 Buat Event Baru</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Nama Event</label><input id="eventTitle" class="input-field" placeholder="Contoh: Team Building 2024"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Deskripsi</label><textarea id="eventDesc" class="input-field" rows="2" placeholder="Deskripsi event..."></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal</label><input id="eventDate" class="input-field" type="date"></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Jam</label><input id="eventTime" class="input-field" type="time"></div>
      </div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Lokasi</label><input id="eventLocation" class="input-field" placeholder="Tempat/Link meeting"></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveEventBtn" onclick="saveEvent()">Buat</button>
    </div>
  `);
  document.getElementById('eventDate').value=new Date().toISOString().split('T')[0];
}

async function saveEvent(){
  const title=document.getElementById('eventTitle').value.trim();
  if(!title){showToast('Nama event harus diisi','error');return}
  const btn=document.getElementById('saveEventBtn');btn.disabled=true;btn.textContent='Membuat...';
  const result=await window.dataSdk.create({
    type:'event',
    employee_id:'',
    event_title:title,
    event_description:document.getElementById('eventDesc').value.trim(),
    event_date:document.getElementById('eventDate').value,
    event_time:document.getElementById('eventTime').value,
    event_location:document.getElementById('eventLocation').value.trim(),
    attendance:'',activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',skill_name:'',skill_level:0,skill_category:'',note_title:'',note_content:'',note_date:'',note_priority:'',note_status:'',project_name:'',project_desc:'',project_status:'',project_lead:'',project_deadline:'',team_members:'',performance_month:'',performance_score:0,performance_feedback:'',training_name:'',training_provider:'',training_date:'',training_duration:'',training_status:'',training_certificate:'',announcement_title:'',announcement_content:'',announcement_date:'',announcement_priority:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Event berhasil dibuat');closeModal();}
  else{showToast('Gagal membuat event','error');btn.disabled=false;btn.textContent='Buat';}
}

// ========== PERFORMANCE REVIEW ==========
function renderPerformanceAdmin(el){
  const reviews=allRecords.filter(r=>r.type==='performance').sort((a,b)=>new Date(b.performance_month)-new Date(a.performance_month));
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">📈 Performance Review</h1>
  <div style="display:grid;gap:12px">
  ${EMPLOYEES.map(emp=>{
    const empReviews=reviews.filter(r=>r.employee_id===emp.id).sort((a,b)=>new Date(b.performance_month)-new Date(a.performance_month));
    const lastReview=empReviews[0];
    const score=lastReview?.performance_score||'-';
    const scoreColor=score!=='-'?(score>=4?'#10b981':score>=3?'#00d4ff':score>=2?'#fbbf24':'#ef4444'):'rgba(226,232,240,0.3)';
    return`<div class="card" style="padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px">
            <div class="avatar" style="width:40px;height:40px;font-size:14px;background:${emp.color};color:#fff">${emp.photo}</div>
            <div>
              <div style="font-size:14px;font-weight:700">${emp.name}</div>
              <div style="font-size:11px;color:rgba(226,232,240,0.4)">${emp.dept}</div>
            </div>
          </div>
          ${lastReview?`<div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:4px">${lastReview.performance_feedback}</div>`:' <div style="font-size:12px;color:rgba(226,232,240,0.3)">Belum ada review</div>'}
        </div>
        <div style="text-align:right">
          <div style="font-size:24px;font-weight:800;color:${scoreColor}">${score}</div>
          <div style="font-size:11px;color:rgba(226,232,240,0.4)">/5.0</div>
          <button class="btn-secondary" style="font-size:10px;padding:3px 10px;margin-top:6px" onclick="openPerformanceReviewModal('${emp.id}')">✏️ Review</button>
        </div>
      </div>
    </div>`;
  }).join('')}
  </div></div>`;
  lucide.createIcons();
}

function openPerformanceReviewModal(empId){
  const emp=EMPLOYEES.find(e=>e.id===empId);
  if(!emp)return;
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:12px">📈 Performance Review</h3>
    <div style="background:rgba(0,212,255,0.08);padding:10px;border-radius:10px;margin-bottom:16px">
      <div style="font-size:13px;font-weight:600">${emp.name}</div>
      <div style="font-size:11px;color:rgba(226,232,240,0.5)">${emp.dept}</div>
    </div>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Periode (Bulan)</label><input id="perfMonth" class="input-field" type="month"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Skor (0-5)</label><input id="perfScore" class="input-field" type="number" min="0" max="5" step="0.1" placeholder="4.5"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Feedback</label><textarea id="perfFeedback" class="input-field" rows="3" placeholder="Komentar performa..."></textarea></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="savePerfBtn" onclick="savePerformanceReview('${empId}')">Simpan</button>
    </div>
  `);
  document.getElementById('perfMonth').value=new Date().toISOString().slice(0,7);
}

async function savePerformanceReview(empId){
  const month=document.getElementById('perfMonth').value;
  const score=parseFloat(document.getElementById('perfScore').value);
  if(!month||!score){showToast('Semua field harus diisi','error');return}
  const btn=document.getElementById('savePerfBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'performance',
    employee_id:empId,
    performance_month:month,
    performance_score:score,
    performance_feedback:document.getElementById('perfFeedback').value.trim(),
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',event_title:'',event_description:'',event_date:'',event_time:'',event_location:'',attendance:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',skill_name:'',skill_level:0,skill_category:'',note_title:'',note_content:'',note_date:'',note_priority:'',note_status:'',project_name:'',project_desc:'',project_status:'',project_lead:'',project_deadline:'',team_members:'',training_name:'',training_provider:'',training_date:'',training_duration:'',training_status:'',training_certificate:'',announcement_title:'',announcement_content:'',announcement_date:'',announcement_priority:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Review berhasil disimpan');closeModal();}
  else{showToast('Gagal menyimpan review','error');btn.disabled=false;btn.textContent='Simpan';}
}

// ========== TRAINING & DEVELOPMENT ==========
function renderTrainingAdmin(el){
  const trainings=allRecords.filter(r=>r.type==='training').sort((a,b)=>new Date(b.training_date)-new Date(a.training_date));
  const completed=trainings.filter(r=>r.training_status==='Completed').length;
  const ongoing=trainings.filter(r=>r.training_status==='Ongoing').length;
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📚 Training & Development</h1>
    <button class="btn-primary" onclick="openAddTrainingModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Buat Program</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📚','Total',trainings.length,'program','#a78bfa')}
    ${statCard('🔄','Ongoing',ongoing,'berlangsung','#fbbf24')}
    ${statCard('✅','Completed',completed,'selesai','#10b981')}
  </div>
  <div style="display:grid;gap:12px">
  ${trainings.length?trainings.map(t=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:15px;font-weight:700">${t.training_name}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">${t.training_provider} • ${formatDate(t.training_date)} (${t.training_duration})</div>
        <div style="display:flex;gap:8px;margin-top:6px;flex-wrap:wrap">
          <span class="badge ${t.training_status==='Completed'?'status-done':t.training_status==='Ongoing'?'status-progress':'status-pending'}">${t.training_status}</span>
          ${t.training_certificate?`<span class="badge" style="background:rgba(16,185,129,0.15);color:#34d399">📜 Sertifikat</span>`:''}
        </div>
      </div>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada program training</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddTrainingModal(){
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📚 Program Training Baru</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Nama Program</label><input id="trainingName" class="input-field" placeholder="Contoh: Leadership Training"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Provider/Penyelenggara</label><input id="trainingProvider" class="input-field" placeholder="Lembaga Training"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal Mulai</label><input id="trainingDate" class="input-field" type="date"></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Durasi</label><input id="trainingDuration" class="input-field" placeholder="5 hari"></div>
      </div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Status</label><select id="trainingStatus" class="input-field"><option value="Planned">Planned</option><option value="Ongoing">Ongoing</option><option value="Completed">Completed</option></select></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveTrainBtn" onclick="saveTraining()">Buat</button>
    </div>
  `);
  document.getElementById('trainingDate').value=new Date().toISOString().split('T')[0];
}

async function saveTraining(){
  const name=document.getElementById('trainingName').value.trim();
  if(!name){showToast('Nama program harus diisi','error');return}
  const btn=document.getElementById('saveTrainBtn');btn.disabled=true;btn.textContent='Membuat...';
  const result=await window.dataSdk.create({
    type:'training',
    employee_id:'',
    training_name:name,
    training_provider:document.getElementById('trainingProvider').value.trim(),
    training_date:document.getElementById('trainingDate').value,
    training_duration:document.getElementById('trainingDuration').value.trim(),
    training_status:document.getElementById('trainingStatus').value,
    training_certificate:'',
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',event_title:'',event_description:'',event_date:'',event_time:'',event_location:'',attendance:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',skill_name:'',skill_level:0,skill_category:'',note_title:'',note_content:'',note_date:'',note_priority:'',note_status:'',project_name:'',project_desc:'',project_status:'',project_lead:'',project_deadline:'',team_members:'',performance_month:'',performance_score:0,performance_feedback:'',announcement_title:'',announcement_content:'',announcement_date:'',announcement_priority:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Program training berhasil dibuat');closeModal();}
  else{showToast('Gagal membuat program','error');btn.disabled=false;btn.textContent='Buat';}
}

// ========== ANNOUNCEMENTS ==========
function renderAnnouncementsAdmin(el){
  const annc=allRecords.filter(r=>r.type==='announcement').sort((a,b)=>new Date(b.announcement_date)-new Date(a.announcement_date));
  const urgent=annc.filter(r=>r.announcement_priority==='Urgent').length;
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📢 Announcements</h1>
    <button class="btn-primary" onclick="openAddAnnouncementModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Post Pengumuman</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📢','Total',annc.length,'pengumuman','#00d4ff')}
    ${statCard('🔴','Urgent',urgent,'penting','#ef4444')}
  </div>
  <div style="display:grid;gap:12px">
  ${annc.length?annc.map(a=>`<div class="card" style="padding:16px;border-left:3px solid ${a.announcement_priority==='Urgent'?'#ef4444':'#00d4ff'}">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:15px;font-weight:700">${a.announcement_title}</div>
        <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:2px">${formatDate(a.announcement_date)}</div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:6px;line-height:1.5">${a.announcement_content}</div>
      </div>
      <span class="badge ${a.announcement_priority==='Urgent'?'status-pending':'status-progress'}">${a.announcement_priority}</span>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada pengumuman</p></div>'}
  </div></div>`;
}

// ========== ATTENDANCE SYSTEM ==========
function renderAttendanceSystem(el){
  const attRecords=allRecords.filter(r=>r.type==='attendance').sort((a,b)=>new Date(b.attendance_date)-new Date(a.attendance_date));
  const present=attRecords.filter(r=>r.attendance_status==='Present').length;
  const absent=attRecords.filter(r=>r.attendance_status==='Absent').length;
  const late=attRecords.filter(r=>r.attendance_status==='Late').length;
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">⏱️ Attendance System</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('✅','Hadir',present,'orang','#10b981')}
    ${statCard('❌','Absen',absent,'orang','#ef4444')}
    ${statCard('⏰','Terlambat',late,'orang','#fbbf24')}
  </div>
  <div style="display:grid;gap:12px">
  ${attRecords.length?attRecords.map(a=>{
    const emp=getEmp(a.employee_id);
    const statusColor=a.attendance_status==='Present'?'#10b981':a.attendance_status==='Absent'?'#ef4444':'#fbbf24';
    return`<div class="card" style="padding:14px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1;display:flex;align-items:center;gap:12px">
          <div class="avatar" style="width:40px;height:40px;font-size:14px;background:${emp?emp.color:'#555'};color:#fff">${emp?emp.photo:'?'}</div>
          <div>
            <div style="font-size:13px;font-weight:600">${emp?emp.name:a.employee_id}</div>
            <div style="font-size:11px;color:rgba(226,232,240,0.4)">📅 ${formatDate(a.attendance_date)} • ${a.check_in_time||'--:--'}</div>
          </div>
        </div>
        <span class="badge" style="background:rgba(${statusColor==='#10b981'?'16,185,129':'239,68,68'},0.15);color:${statusColor}">${a.attendance_status}</span>
      </div>
    </div>`;
  }).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada data attendance</p></div>'}
  </div></div>`;
}

// ========== REWARDS & INCENTIVES ==========
function renderRewardsAdmin(el){
  const rewards=allRecords.filter(r=>r.type==='reward').sort((a,b)=>new Date(b.reward_date)-new Date(a.reward_date));
  const totalPoints=rewards.reduce((sum,r)=>sum+(r.reward_points||0),0);
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">🎁 Rewards & Incentives</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('⭐','Total Rewards',rewards.length,'pemberian','#fbbf24')}
    ${statCard('💎','Total Points',totalPoints,'poin','#00d4ff')}
  </div>
  <div style="display:grid;gap:12px">
  ${EMPLOYEES.map(emp=>{
    const empRewards=rewards.filter(r=>r.employee_id===emp.id);
    const empPoints=empRewards.reduce((s,r)=>s+(r.reward_points||0),0);
    return`<div class="card" style="padding:14px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1;display:flex;align-items:center;gap:12px">
          <div class="avatar" style="width:40px;height:40px;font-size:14px;background:${emp.color};color:#fff">${emp.photo}</div>
          <div>
            <div style="font-size:13px;font-weight:700">${emp.name}</div>
            <div style="font-size:11px;color:rgba(226,232,240,0.4)">${emp.dept} • ${empRewards.length} reward</div>
          </div>
        </div>
        <div style="text-align:right">
          <div style="font-size:18px;font-weight:800;color:#fbbf24">💎 ${empPoints}</div>
          <button class="btn-secondary" style="font-size:10px;padding:3px 10px;margin-top:4px" onclick="openGiveRewardModal('${emp.id}')">+</button>
        </div>
      </div>
    </div>`;
  }).join('')}
  </div></div>`;
  lucide.createIcons();
}

function openGiveRewardModal(empId){
  const emp=EMPLOYEES.find(e=>e.id===empId);
  if(!emp)return;
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:12px">🎁 Berikan Reward</h3>
    <div style="background:rgba(251,191,36,0.08);padding:10px;border-radius:10px;margin-bottom:16px">
      <div style="font-size:13px;font-weight:600">${emp.name}</div>
    </div>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Nama Reward</label><input id="rewardName" class="input-field" placeholder="Contoh: Bonus Performa"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Poin</label><input id="rewardPoints" class="input-field" type="number" min="1" placeholder="100"></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="giveRewardBtn" onclick="giveReward('${empId}')">Berikan</button>
    </div>
  `);
}

async function giveReward(empId){
  const name=document.getElementById('rewardName').value.trim();
  const points=parseInt(document.getElementById('rewardPoints').value);
  if(!name||!points){showToast('Semua field harus diisi','error');return}
  const btn=document.getElementById('giveRewardBtn');btn.disabled=true;btn.textContent='Memberikan...';
  const result=await window.dataSdk.create({
    type:'reward',
    employee_id:empId,
    reward_name:name,
    reward_points:points,
    reward_date:new Date().toISOString(),
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',attendance_status:'',check_in_time:'',check_out_time:'',attendance_date:'',discipline_type:'',discipline_level:'',discipline_reason:'',warning_count:0,salary_month:'',salary_amount:0,bonus:0,deduction:0,payslip_status:'',meeting_title:'',meeting_date:'',meeting_time:'',meeting_location:'',meeting_notes:'',attendees:'',document_type:'',document_name:'',document_date:'',document_expiry:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('🎁 Reward berhasil diberikan!');closeModal();}
  else{showToast('Gagal memberikan reward','error');btn.disabled=false;btn.textContent='Berikan';}
}

// ========== DISCIPLINE MANAGEMENT ==========
function renderDisciplineAdmin(el){
  const records=allRecords.filter(r=>r.type==='discipline').sort((a,b)=>new Date(b.discipline_reason)-new Date(a.discipline_reason));
  const warning=records.filter(r=>r.discipline_level==='Warning').length;
  const suspension=records.filter(r=>r.discipline_level==='Suspension').length;
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">⚠️ Discipline Management</h1>
    <button class="btn-primary" onclick="openAddDisciplineModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Catat Disiplin</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('⚠️','Total',records.length,'kasus','#ef4444')}
    ${statCard('🟡','Warning',warning,'diberikan','#fbbf24')}
    ${statCard('🔴','Suspension',suspension,'kasus','#ef4444')}
  </div>
  <div style="display:grid;gap:12px">
  ${records.length?records.map(d=>{
    const emp=getEmp(d.employee_id);
    return`<div class="card" style="padding:14px;border-left:3px solid ${d.discipline_level==='Warning'?'#fbbf24':'#ef4444'}">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1">
          <div style="font-size:13px;font-weight:700">${emp?emp.name:d.employee_id}</div>
          <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:2px">${d.discipline_type} • Level: ${d.discipline_level}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:4px">${d.discipline_reason}</div>
        </div>
        <span class="badge" style="background:rgba(${d.discipline_level==='Warning'?'251,191,36':'239,68,68'},0.15);color:${d.discipline_level==='Warning'?'#fbbf24':'#ef4444'}">${d.discipline_level}</span>
      </div>
    </div>`;
  }).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada catatan disiplin</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddDisciplineModal(){
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">⚠️ Catat Disiplin</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Karyawan</label>
      <select id="discEmp" class="input-field">
        <option value="">-- Pilih Karyawan --</option>
        ${EMPLOYEES.map(e=>`<option value="${e.id}">${e.name}</option>`).join('')}
      </select></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tipe Pelanggaran</label><input id="discType" class="input-field" placeholder="Contoh: Terlambat, Tidak Hadir"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Level</label><select id="discLevel" class="input-field"><option value="Warning">Warning 🟡</option><option value="Suspension">Suspension 🔴</option></select></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Alasan</label><textarea id="discReason" class="input-field" rows="3" placeholder="Penjelasan pelanggaran..."></textarea></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveDisciplineBtn" onclick="saveDiscipline()">Catat</button>
    </div>
  `);
}

async function saveDiscipline(){
  const empId=document.getElementById('discEmp').value;
  const type=document.getElementById('discType').value.trim();
  if(!empId||!type){showToast('Semua field harus diisi','error');return}
  const btn=document.getElementById('saveDisciplineBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'discipline',
    employee_id:empId,
    discipline_type:type,
    discipline_level:document.getElementById('discLevel').value,
    discipline_reason:document.getElementById('discReason').value.trim(),
    warning_count:0,activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',attendance_status:'',check_in_time:'',check_out_time:'',attendance_date:'',reward_name:'',reward_points:0,reward_date:'',salary_month:'',salary_amount:0,bonus:0,deduction:0,payslip_status:'',meeting_title:'',meeting_date:'',meeting_time:'',meeting_location:'',meeting_notes:'',attendees:'',document_type:'',document_name:'',document_date:'',document_expiry:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Catatan disiplin berhasil disimpan');closeModal();}
  else{showToast('Gagal menyimpan catatan','error');btn.disabled=false;btn.textContent='Catat';}
}

// ========== PAYROLL MANAGEMENT ==========
function renderPayrollAdmin(el){
  const payrolls=allRecords.filter(r=>r.type==='payroll').sort((a,b)=>new Date(b.salary_month)-new Date(a.salary_month));
  const totalSalary=payrolls.reduce((s,p)=>s+(p.salary_amount||0),0);
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">💰 Payroll & Salary</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('💳','Total Gaji',payrolls.length,'karyawan','#00d4ff')}
    ${statCard('💵','Total Bayar','Rp '+totalSalary.toLocaleString('id-ID'),'bulan ini','#10b981')}
  </div>
  <div style="overflow-x:auto">
  <table style="width:100%;border-collapse:collapse;font-size:12px">
    <thead><tr style="border-bottom:2px solid rgba(0,212,255,0.2)">
      <th style="text-align:left;padding:10px;color:var(--accent)">Karyawan</th>
      <th style="text-align:center;padding:10px;color:var(--accent)">Periode</th>
      <th style="text-align:right;padding:10px;color:var(--accent)">Gaji</th>
      <th style="text-align:right;padding:10px;color:var(--accent)">Bonus</th>
      <th style="text-align:right;padding:10px;color:var(--accent)">Potongan</th>
      <th style="text-align:center;padding:10px;color:var(--accent)">Status</th>
    </tr></thead>
    <tbody>${EMPLOYEES.map(emp=>{
      const payroll=payrolls.find(p=>p.employee_id===emp.id);
      if(!payroll)return`<tr style="border-bottom:1px solid rgba(255,255,255,0.03)"><td colspan="6" style="padding:10px;text-align:center;color:rgba(226,232,240,0.3)">-</td></tr>`;
      return`<tr style="border-bottom:1px solid rgba(255,255,255,0.03)">
        <td style="padding:10px"><div style="font-weight:600">${emp.name}</div></td>
        <td style="text-align:center;padding:10px">${payroll.salary_month}</td>
        <td style="text-align:right;padding:10px;color:#10b981"><b>Rp ${(payroll.salary_amount||0).toLocaleString('id-ID')}</b></td>
        <td style="text-align:right;padding:10px;color:#fbbf24">${payroll.bonus||0}</td>
        <td style="text-align:right;padding:10px;color:#ef4444">-${payroll.deduction||0}</td>
        <td style="text-align:center;padding:10px"><span class="badge" style="background:rgba(16,185,129,0.15);color:#34d399">Bayar</span></td>
      </tr>`;
    }).join('')}</tbody>
  </table>
  </div></div>`;
}

// ========== MEETING MANAGEMENT ==========
function renderMeetingsAdmin(el){
  const meetings=allRecords.filter(r=>r.type==='meeting').sort((a,b)=>new Date(b.meeting_date)-new Date(a.meeting_date));
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📹 Meeting Management</h1>
    <button class="btn-primary" onclick="openAddMeetingModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Jadwalkan Meeting</button>
  </div>
  <div style="display:grid;gap:12px">
  ${meetings.length?meetings.map(m=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${m.meeting_title}</div>
        <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:2px">📅 ${formatDate(m.meeting_date)} • 🕐 ${m.meeting_time||'--:--'} • 📍 ${m.meeting_location||'Online'}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:6px">${m.meeting_notes||'Tanpa catatan'}</div>
        ${m.attendees?`<div style="font-size:11px;color:rgba(226,232,240,0.5);margin-top:4px">👥 Peserta: ${m.attendees}</div>`:''}
      </div>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada meeting dijadwalkan</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddMeetingModal(){
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📹 Jadwalkan Meeting</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Judul Meeting</label><input id="mtgTitle" class="input-field" placeholder="Contoh: Review Q4"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal</label><input id="mtgDate" class="input-field" type="date"></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Jam</label><input id="mtgTime" class="input-field" type="time"></div>
      </div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Lokasi/Link</label><input id="mtgLocation" class="input-field" placeholder="Zoom/Office"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Peserta</label><input id="mtgAttendees" class="input-field" placeholder="Nama peserta, dipisah koma"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Catatan</label><textarea id="mtgNotes" class="input-field" rows="2" placeholder="Agenda meeting..."></textarea></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveMtgBtn" onclick="saveMeeting()">Jadwalkan</button>
    </div>
  `);
  document.getElementById('mtgDate').value=new Date().toISOString().split('T')[0];
}

async function saveMeeting(){
  const title=document.getElementById('mtgTitle').value.trim();
  if(!title){showToast('Judul meeting harus diisi','error');return}
  const btn=document.getElementById('saveMtgBtn');btn.disabled=true;btn.textContent='Menjadwalkan...';
  const result=await window.dataSdk.create({
    type:'meeting',
    employee_id:'',
    meeting_title:title,
    meeting_date:document.getElementById('mtgDate').value,
    meeting_time:document.getElementById('mtgTime').value,
    meeting_location:document.getElementById('mtgLocation').value.trim(),
    meeting_notes:document.getElementById('mtgNotes').value.trim(),
    attendees:document.getElementById('mtgAttendees').value.trim(),
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',attendance_status:'',check_in_time:'',check_out_time:'',attendance_date:'',reward_name:'',reward_points:0,reward_date:'',discipline_type:'',discipline_level:'',discipline_reason:'',warning_count:0,salary_month:'',salary_amount:0,bonus:0,deduction:0,payslip_status:'',document_type:'',document_name:'',document_date:'',document_expiry:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Meeting berhasil dijadwalkan');closeModal();}
  else{showToast('Gagal menjadwalkan meeting','error');btn.disabled=false;btn.textContent='Jadwalkan';}
}

lucide.createIcons();
</script>
