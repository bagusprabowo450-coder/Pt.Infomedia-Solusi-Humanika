}

// Close modal on overlay click
document.getElementById('modalOverlay').addEventListener('click',function(e){
  if(e.target===this)closeModal();
});

// ========== GOALS & OKR ==========
function renderGoalsAdmin(el){
  const goals=allRecords.filter(r=>r.type==='goal').sort((a,b)=>new Date(b.goal_deadline)-new Date(a.goal_deadline));
  const active=goals.filter(r=>r.goal_status==='In Progress').length;
  const completed=goals.filter(r=>r.goal_status==='Completed').length;
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">🎯 OKR & Goals</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('🎯','Total Goals',goals.length,'goals','#7c3aed')}
    ${statCard('⏳','In Progress',active,'aktif','#fbbf24')}
    ${statCard('✅','Completed',completed,'selesai','#10b981')}
  </div>
  <div style="display:grid;gap:12px">
  ${goals.length?goals.map(g=>{
    const pct=g.goal_target?(g.goal_progress/g.goal_target*100).toFixed(0):0;
    return`<div class="card" style="padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1;min-width:200px">
          <div style="font-size:15px;font-weight:700">${g.goal_title}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">Owner: ${g.goal_owner} • Deadline: ${formatDate(g.goal_deadline)}</div>
          <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${g.goal_description}</div>
          <div style="margin-top:8px;display:flex;align-items:center;gap:8px">
            <div class="progress-bar" style="flex:1"><div class="progress-fill" style="width:${pct}%"></div></div>
            <span style="font-size:12px;font-weight:700;color:var(--accent)">${pct}%</span>
          </div>
          <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:4px">${g.goal_progress}/${g.goal_target} target</div>
        </div>
        <div style="text-align:right">
          <span class="badge ${g.goal_status==='Completed'?'status-done':g.goal_status==='In Progress'?'status-progress':'status-pending'}">${g.goal_status}</span>
        </div>
      </div>
    </div>`;
  }).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada goal yang dibuat</p></div>'}
  </div></div>`;
}

function renderMyGoals(el){
  const goals=getEmpRecords(currentUser.emp.id).filter(r=>r.type==='goal').sort((a,b)=>new Date(b.goal_deadline)-new Date(a.goal_deadline));
  const active=goals.filter(r=>r.goal_status==='In Progress').length;
  const completed=goals.filter(r=>r.goal_status==='Completed').length;
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">🎯 Goal Saya</h1>
    <button class="btn-primary" onclick="openAddGoalModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Buat Goal</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px">
    ${statCard('🎯','Total',goals.length,'goals','#7c3aed')}
    ${statCard('⏳','In Progress',active,'aktif','#fbbf24')}
    ${statCard('✅','Completed',completed,'selesai','#10b981')}
  </div>
  <div style="display:grid;gap:12px">
  ${goals.length?goals.map(g=>{
    const pct=g.goal_target?(g.goal_progress/g.goal_target*100).toFixed(0):0;
    return`<div class="card" style="padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1;min-width:200px">
          <div style="font-size:15px;font-weight:700">${g.goal_title}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">Deadline: ${formatDate(g.goal_deadline)}</div>
          <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${g.goal_description}</div>
          <div style="margin-top:8px;display:flex;align-items:center;gap:8px">
            <div class="progress-bar" style="flex:1"><div class="progress-fill" style="width:${pct}%"></div></div>
            <span style="font-size:12px;font-weight:700;color:var(--accent)">${pct}%</span>
          </div>
          <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:4px">${g.goal_progress}/${g.goal_target} target</div>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <span class="badge ${g.goal_status==='Completed'?'status-done':g.goal_status==='In Progress'?'status-progress':'status-pending'}">${g.goal_status}</span>
          <button class="btn-secondary" style="font-size:11px;padding:3px 8px" onclick="updateGoalProgress('${g.__backendId}')">📈 Update</button>
        </div>
      </div>
    </div>`;
  }).join(''):'<div class="card" style="text-align:center;padding:40px"><p style="color:rgba(226,232,240,0.3)">Belum ada goal. Buat goal untuk mencapai target kerja Anda.</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddGoalModal(){
  if(allRecords.filter(r=>r.employee_id===currentUser.emp.id).length>=999){showToast('Batas data tercapai','error');return}
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">🎯 Buat Goal Baru</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Judul Goal</label><input id="goalTitle" class="input-field" placeholder="Contoh: Tingkatkan penjualan 50%"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Deskripsi</label><textarea id="goalDesc" class="input-field" rows="2" placeholder="Penjelasan detail goal..."></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Target (angka)</label><input id="goalTarget" class="input-field" type="number" min="1" placeholder="Contoh: 100"></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Deadline</label><input id="goalDeadline" class="input-field" type="date"></div>
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveGoalBtn" onclick="saveGoal()">Buat Goal</button>
    </div>
  `);
  document.getElementById('goalDeadline').value=new Date(Date.now()+30*24*60*60*1000).toISOString().split('T')[0];
}

async function saveGoal(){
  const title=document.getElementById('goalTitle').value.trim();
  const target=parseInt(document.getElementById('goalTarget').value);
  if(!title||!target){showToast('Semua field harus diisi','error');return}
  const btn=document.getElementById('saveGoalBtn');btn.disabled=true;btn.textContent='Membuat...';
  const result=await window.dataSdk.create({
    type:'goal',
    employee_id:currentUser.emp.id,
    goal_title:title,
    goal_description:document.getElementById('goalDesc').value.trim(),
    goal_target:target,
    goal_progress:0,
    goal_deadline:document.getElementById('goalDeadline').value,
    goal_owner:currentUser.emp.name,
    goal_status:'In Progress',
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',overtime_hours:0,overtime_date:'',overtime_reason:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Goal berhasil dibuat');closeModal();}
  else{showToast('Gagal membuat goal','error');btn.disabled=false;btn.textContent='Buat Goal';}
}

async function updateGoalProgress(backendId){
  const rec=allRecords.find(r=>r.__backendId===backendId);if(!rec)return;
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📈 Update Progress Goal</h3>
    <div style="background:rgba(0,212,255,0.08);padding:12px;border-radius:10px;margin-bottom:16px">
      <div style="font-size:13px;font-weight:600">${rec.goal_title}</div>
      <div style="font-size:12px;color:rgba(226,232,240,0.5);margin-top:4px">Target: ${rec.goal_target}</div>
    </div>
    <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Progress Terkini</label><input id="newProgress" class="input-field" type="number" min="0" max="${rec.goal_target}" value="${rec.goal_progress||0}"></div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="updateProgBtn" onclick="doUpdateProgress('${backendId}')">Update</button>
    </div>
  `);
}

async function doUpdateProgress(backendId){
  const rec=allRecords.find(r=>r.__backendId===backendId);if(!rec)return;
  const progress=parseInt(document.getElementById('newProgress').value);
  const btn=document.getElementById('updateProgBtn');btn.disabled=true;btn.textContent='Update...';
  const isCompleted=progress>=rec.goal_target;
  const result=await window.dataSdk.update({...rec,goal_progress:progress,goal_status:isCompleted?'Completed':'In Progress'});
  if(result.isOk){showToast(isCompleted?'🎉 Goal selesai!':'Progress diupdate');closeModal();}
  else{showToast('Gagal update progress','error');btn.disabled=false;btn.textContent='Update';}
}

// ========== BADGES & ACHIEVEMENTS ==========
function renderBadgesAdmin(el){
  const badgeRecords=allRecords.filter(r=>r.type==='badge');
  const uniqueBadges=new Map();
  badgeRecords.forEach(b=>{uniqueBadges.set(b.badge_name,b)});
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">🏅 Badges & Achievements</h1>
    <button class="btn-primary" onclick="openAddBadgeModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Buat Badge</button>
  </div>
  <div style="display:grid;gap:12px">
  ${Array.from(uniqueBadges.values()).length?Array.from(uniqueBadges.values()).map(b=>{
    const holders=badgeRecords.filter(r=>r.badge_name===b.badge_name).map(r=>r.employee_id).join(', ');
    return`<div class="card" style="padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1">
          <div style="font-size:24px;margin-bottom:4px">${b.badge_icon}</div>
          <div style="font-size:15px;font-weight:700">${b.badge_name}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:4px">${b.badge_criteria}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:6px">📊 Diraih: ${badgeRecords.filter(r=>r.badge_name===b.badge_name).length} karyawan</div>
        </div>
        <button class="btn-secondary" style="font-size:11px;padding:4px 12px" onclick="openGiveBadgeModal('${b.badge_name}','${b.badge_icon}')">🎁 Berikan</button>
      </div>
    </div>`;
  }).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada badge dibuat</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function renderMyBadges(el){
  const emp=currentUser.emp;
  const myBadges=allRecords.filter(r=>r.type==='badge'&&r.employee_id===emp.id).sort((a,b)=>new Date(b.badge_date)-new Date(a.badge_date));
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">🏅 Achievement Badge Saya</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px">
  ${myBadges.length?myBadges.map(b=>`<div class="card" style="padding:20px;text-align:center;background:linear-gradient(135deg,rgba(0,212,255,0.1),rgba(124,58,237,0.1));border:1px solid rgba(0,212,255,0.2)">
    <div style="font-size:48px;margin-bottom:8px">${b.badge_icon}</div>
    <div style="font-size:15px;font-weight:700">${b.badge_name}</div>
    <div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:4px">${b.badge_criteria}</div>
    <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:8px">✨ ${formatDate(b.badge_date)}</div>
  </div>`).join(''):'<div class="card" style="grid-column:1/-1;text-align:center;padding:40px"><p style="color:rgba(226,232,240,0.3)">Belum ada achievement badge. Terus tingkatkan performa Anda!</p></div>'}
  </div></div>`;
}

