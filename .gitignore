<!doctype html>
<html lang="id" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PT. Infomedia Solusi Humanika - Employee Monitoring</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet">
  <style>
*{font-family:'Plus Jakarta Sans',sans-serif;margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;width:100%;overflow:hidden}
:root{--bg:#0a0e1a;--surface:#111827;--surface2:#1a2236;--accent:#00d4ff;--accent2:#7c3aed;--text:#e2e8f0;--glow:0 0 20px rgba(0,212,255,0.3);--glow2:0 0 20px rgba(124,58,237,0.3)}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--surface)}
::-webkit-scrollbar-thumb{background:var(--accent);border-radius:3px}
.glow-border{border:1px solid rgba(0,212,255,0.3);box-shadow:var(--glow)}
.glow-border2{border:1px solid rgba(124,58,237,0.3);box-shadow:var(--glow2)}
.glow-text{text-shadow:0 0 10px rgba(0,212,255,0.5)}
.glow-text2{text-shadow:0 0 10px rgba(124,58,237,0.5)}
.card{background:var(--surface);border-radius:16px;padding:20px;border:1px solid rgba(255,255,255,0.05);transition:all .3s}
.card:hover{border-color:rgba(0,212,255,0.2);box-shadow:0 0 30px rgba(0,212,255,0.1)}
.btn-primary{background:linear-gradient(135deg,#00d4ff,#7c3aed);color:#fff;border:none;padding:10px 24px;border-radius:10px;cursor:pointer;font-weight:600;transition:all .3s;font-size:14px}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 4px 20px rgba(0,212,255,0.4)}
.btn-primary:disabled{opacity:0.5;cursor:not-allowed;transform:none}
.btn-secondary{background:transparent;color:var(--accent);border:1px solid rgba(0,212,255,0.3);padding:8px 20px;border-radius:10px;cursor:pointer;font-weight:500;transition:all .3s;font-size:13px}
.btn-secondary:hover{background:rgba(0,212,255,0.1);box-shadow:var(--glow)}
.input-field{background:var(--surface2);border:1px solid rgba(255,255,255,0.1);color:var(--text);padding:10px 14px;border-radius:10px;width:100%;font-size:14px;transition:all .3s;font-family:'Plus Jakarta Sans',sans-serif}
.input-field:focus{outline:none;border-color:var(--accent);box-shadow:0 0 15px rgba(0,212,255,0.2)}
.badge{display:inline-flex;align-items:center;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;letter-spacing:0.5px}
.badge-cmo{background:rgba(0,212,255,0.15);color:#00d4ff}
.badge-hr{background:rgba(124,58,237,0.15);color:#a78bfa}
.badge-am{background:rgba(16,185,129,0.15);color:#34d399}
.status-done{background:rgba(16,185,129,0.15);color:#34d399}
.status-progress{background:rgba(251,191,36,0.15);color:#fbbf24}
.status-pending{background:rgba(239,68,68,0.15);color:#ef4444}
.star{cursor:pointer;transition:all .2s}
.star:hover{transform:scale(1.2)}
.star.active{color:#fbbf24;filter:drop-shadow(0 0 4px rgba(251,191,36,0.5))}
.sidebar-item{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:12px;cursor:pointer;transition:all .3s;color:rgba(226,232,240,0.6);font-size:14px;font-weight:500}
.sidebar-item:hover,.sidebar-item.active{background:rgba(0,212,255,0.1);color:var(--accent)}
.sidebar-item.active{border-left:3px solid var(--accent)}
.animate-in{animation:fadeSlideIn .4s ease forwards;opacity:0}
@keyframes fadeSlideIn{from{opacity:0;transform:translateY(15px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse-glow{0%,100%{box-shadow:0 0 5px rgba(0,212,255,0.3)}50%{box-shadow:0 0 25px rgba(0,212,255,0.6)}}
.pulse-indicator{animation:pulse-glow 2s infinite}
.toast{position:fixed;top:20px;right:20px;padding:14px 24px;border-radius:12px;z-index:9999;transform:translateX(120%);transition:transform .3s ease;font-weight:500;font-size:14px}
.toast.show{transform:translateX(0)}
.toast-success{background:linear-gradient(135deg,#065f46,#064e3b);color:#34d399;border:1px solid rgba(52,211,153,0.3)}
.toast-error{background:linear-gradient(135deg,#7f1d1d,#991b1b);color:#fca5a5;border:1px solid rgba(252,165,165,0.3)}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);z-index:1000;display:none;align-items:center;justify-content:center;padding:16px}
.modal-overlay.show{display:flex}
.modal-content{background:var(--surface);border-radius:20px;padding:28px;max-width:500px;width:100%;border:1px solid rgba(0,212,255,0.2);box-shadow:0 0 40px rgba(0,212,255,0.15);max-height:90%;overflow-y:auto}
.progress-bar{height:6px;background:var(--surface2);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#00d4ff,#7c3aed);transition:width .6s ease}
.chart-bar{border-radius:6px 6px 0 0;transition:height .6s ease;position:relative}
.chart-bar:hover{filter:brightness(1.2)}
.avatar{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;flex-shrink:0}
.tab-btn{padding:8px 16px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;transition:all .3s;border:none;color:rgba(226,232,240,0.5);background:transparent}
.tab-btn.active{background:rgba(0,212,255,0.15);color:#00d4ff}
.confirm-bar{display:flex;gap:8px;align-items:center;padding:8px 12px;background:rgba(239,68,68,0.1);border-radius:10px;border:1px solid rgba(239,68,68,0.2)}
@media(max-width:768px){
.sidebar-desktop{display:none!important}
.main-shift{margin-left:0!important}
.mobile-header{display:flex!important}
}
@media(min-width:769px){
.mobile-header{display:none!important}
.mobile-menu{display:none!important}
}
</style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body style="background:var(--bg);color:var(--text);height:100%;overflow:hidden">
  <div id="app" style="height:100%;overflow:auto;width:100%">
   <!-- TOAST -->
   <div id="toast" class="toast"></div><!-- LOGIN PAGE -->
   <div id="loginPage" style="height:100%;display:flex;align-items:center;justify-content:center;padding:20px;background:radial-gradient(ellipse at 30% 20%,rgba(0,212,255,0.08),transparent 60%),radial-gradient(ellipse at 70% 80%,rgba(124,58,237,0.08),transparent 60%),var(--bg)">
    <div style="max-width:420px;width:100%">
     <div style="text-align:center;margin-bottom:32px" class="animate-in">
      <div style="width:70px;height:70px;margin:0 auto 16px;border-radius:18px;background:linear-gradient(135deg,#00d4ff,#7c3aed);display:flex;align-items:center;justify-content:center" class="pulse-indicator">
       <svg width="36" height="36" fill="none" stroke="#fff" stroke-width="2" viewbox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
       </svg>
      </div>
      <h1 style="font-size:22px;font-weight:800;background:linear-gradient(135deg,#00d4ff,#7c3aed);-webkit-background-clip:text;-webkit-text-fill-color:transparent" id="loginCompanyName">PT. Infomedia Solusi Humanika</h1>
      <p style="color:rgba(226,232,240,0.5);font-size:13px;margin-top:4px" id="loginSystemTitle">Employee Monitoring System</p>
     </div>
     <div class="card glow-border animate-in" style="animation-delay:.1s">
      <div style="display:flex;gap:0;margin-bottom:24px;background:var(--surface2);border-radius:10px;padding:4px">
       <button id="loginTabEmployee" class="tab-btn active" style="flex:1" onclick="switchLoginTab('employee')">🧑💼 Karyawan</button> <button id="loginTabAdmin" class="tab-btn" style="flex:1" onclick="switchLoginTab('admin')">🔐 Admin</button>
      </div>
      <div id="loginForm">
       <div style="margin-bottom:16px">
        <label style="font-size:12px;color:rgba(226,232,240,0.5);margin-bottom:6px;display:block">Username</label> <input id="loginUser" class="input-field" placeholder="Masukkan username" autocomplete="off">
       </div>
       <div style="margin-bottom:20px">
        <label style="font-size:12px;color:rgba(226,232,240,0.5);margin-bottom:6px;display:block">Password</label> <input id="loginPass" class="input-field" type="password" placeholder="Masukkan password">
       </div><button class="btn-primary" style="width:100%;padding:12px" onclick="handleLogin()" id="loginBtn">Masuk</button>
       <p id="loginError" style="color:#ef4444;font-size:12px;margin-top:10px;text-align:center;display:none"></p>
      </div>
      <div style="margin-top:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.05);font-size:11px;color:rgba(226,232,240,0.3);text-align:center">
       <div id="loginHint">
        Karyawan: nama depan kecil / pass: infomedia123
       </div>
      </div>
     </div>
    </div>
   </div><!-- MAIN DASHBOARD -->
   <div id="dashboard" style="display:none;height:100%">
    <!-- SIDEBAR DESKTOP -->
    <aside class="sidebar-desktop" style="position:fixed;left:0;top:0;bottom:0;width:240px;background:var(--surface);border-right:1px solid rgba(255,255,255,0.05);padding:20px 12px;overflow-y:auto;z-index:100">
     <div style="display:flex;align-items:center;gap:10px;padding:0 8px 20px;border-bottom:1px solid rgba(255,255,255,0.05);margin-bottom:16px">
      <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#00d4ff,#7c3aed);display:flex;align-items:center;justify-content:center;flex-shrink:0">
       <svg width="20" height="20" fill="none" stroke="#fff" stroke-width="2" viewbox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
       </svg>
      </div>
      <div>
       <div style="font-size:12px;font-weight:700;color:var(--accent)" id="sidebarCompany">
        ISH Monitor
       </div>
       <div style="font-size:10px;color:rgba(226,232,240,0.4)">
        v2.0
       </div>
      </div>
     </div>
     <nav id="sidebarNav"></nav>
     <div style="margin-top:auto;padding-top:20px;border-top:1px solid rgba(255,255,255,0.05);margin-top:20px">
      <div class="sidebar-item" onclick="handleLogout()" style="color:rgba(239,68,68,0.7)">
       <i data-lucide="log-out" style="width:18px;height:18px"></i>Keluar
      </div>
     </div>
    </aside><!-- MOBILE HEADER -->
    <header class="mobile-header" style="display:none;position:fixed;top:0;left:0;right:0;height:56px;background:var(--surface);border-bottom:1px solid rgba(255,255,255,0.05);align-items:center;justify-content:space-between;padding:0 16px;z-index:200">
     <div style="display:flex;align-items:center;gap:10px">
      <button onclick="toggleMobileMenu()" style="background:none;border:none;color:var(--text);cursor:pointer"><i data-lucide="menu" style="width:22px;height:22px"></i></button> <span style="font-size:14px;font-weight:700;color:var(--accent)">ISH Monitor</span>
     </div>
     <div id="mobileUserBadge" style="display:flex;align-items:center;gap:8px">
      <div class="avatar" style="width:32px;height:32px;font-size:12px;background:linear-gradient(135deg,#00d4ff,#7c3aed);color:#fff" id="mobileAvatar">
       U
      </div>
     </div>
    </header><!-- MOBILE MENU OVERLAY -->
    <div id="mobileMenu" class="mobile-menu" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:300">
     <div style="width:260px;height:100%;background:var(--surface);padding:20px 12px;overflow-y:auto">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:0 8px 16px;border-bottom:1px solid rgba(255,255,255,0.05);margin-bottom:16px">
       <span style="font-weight:700;color:var(--accent)">Menu</span> <button onclick="toggleMobileMenu()" style="background:none;border:none;color:var(--text);cursor:pointer"><i data-lucide="x" style="width:20px;height:20px"></i></button>
      </div>
      <nav id="mobileNav"></nav>
      <div style="margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.05)">
       <div class="sidebar-item" onclick="handleLogout()" style="color:rgba(239,68,68,0.7)">
        <i data-lucide="log-out" style="width:18px;height:18px"></i>Keluar
       </div>
      </div>
     </div>
    </div><!-- MAIN CONTENT -->
    <main id="mainContent" class="main-shift" style="margin-left:240px;padding:24px;padding-top:24px;height:100%;overflow-y:auto">
    </main>
   </div><!-- MODALS -->
   <div id="modalOverlay" class="modal-overlay">
    <div class="modal-content" id="modalContent"></div>
   </div>
  </div>
  <script>
// ========== STATE ==========
let currentUser = null;
let currentView = 'dashboard';
let loginMode = 'employee';
let allRecords = [];
let isMobileMenuOpen = false;

const EMPLOYEES = [
  {id:'dinda',name:'Dinda Ayu Lestari',dept:'CMO',role:'Content Marketing Officer',email:'dinda@infomedia.co.id',phone:'0812-3456-7890',joined:'2023-01-15',photo:'DA',color:'#00d4ff'},
  {id:'dirga',name:'Dirga Wahyuzar',dept:'CMO',role:'Content Marketing Officer',email:'dirga@infomedia.co.id',phone:'0813-4567-8901',joined:'2023-03-20',photo:'DW',color:'#06b6d4'},
  {id:'muhammad',name:'Muhammad Heri',dept:'HR',role:'Human Resources Staff',email:'heri@infomedia.co.id',phone:'0814-5678-9012',joined:'2022-08-10',photo:'MH',color:'#7c3aed'},
  {id:'aprilia',name:'Aprilia Hikari Dewi',dept:'HR',role:'Human Resources Staff',email:'aprilia@infomedia.co.id',phone:'0815-6789-0123',joined:'2023-06-01',photo:'AH',color:'#8b5cf6'},
  {id:'frans',name:'Frans Hutajulu',dept:'AM',role:'Account Manager',email:'frans@infomedia.co.id',phone:'0816-7890-1234',joined:'2022-11-05',photo:'FH',color:'#10b981'}
];

const USERS = {
  dinda:{pass:'infomedia123',empId:'dinda',type:'employee'},
  dirga:{pass:'infomedia123',empId:'dirga',type:'employee'},
  muhammad:{pass:'infomedia123',empId:'muhammad',type:'employee'},
  aprilia:{pass:'infomedia123',empId:'aprilia',type:'employee'},
  frans:{pass:'infomedia123',empId:'frans',type:'employee'},
  admin:{pass:'admin123',type:'admin',name:'Manager / Asman'},
  manager:{pass:'manager123',type:'admin',name:'Manager'},
  asman:{pass:'asman123',type:'admin',name:'Asman'}
};

const defaultConfig = {
  company_name:'PT. Infomedia Solusi Humanika',
  system_title:'Employee Monitoring System',
  background_color:'#0a0e1a',
  surface_color:'#111827',
  text_color:'#e2e8f0',
  accent_color:'#00d4ff',
  accent2_color:'#7c3aed'
};

// ========== ELEMENT SDK INIT ==========
window.elementSdk.init({
  defaultConfig,
  onConfigChange:async(config)=>{
    const c=k=>config[k]||defaultConfig[k];
    document.documentElement.style.setProperty('--bg',c('background_color'));
    document.documentElement.style.setProperty('--surface',c('surface_color'));
    document.documentElement.style.setProperty('--text',c('text_color'));
    document.documentElement.style.setProperty('--accent',c('accent_color'));
    document.documentElement.style.setProperty('--accent2',c('accent2_color'));
    const cn=c('company_name'), st=c('system_title');
    const el1=document.getElementById('loginCompanyName');if(el1)el1.textContent=cn;
    const el2=document.getElementById('loginSystemTitle');if(el2)el2.textContent=st;
    const el3=document.getElementById('sidebarCompany');if(el3)el3.textContent=cn.length>20?'ISH Monitor':cn;
  },
  mapToCapabilities:(config)=>{
    const c=k=>config[k]||defaultConfig[k];
    const mk=(key)=>({get:()=>c(key),set:v=>{config[key]=v;window.elementSdk.setConfig({[key]:v})}});
    return{
      recolorables:[mk('background_color'),mk('surface_color'),mk('text_color'),mk('accent_color'),mk('accent2_color')],
      borderables:[],
      fontEditable:{get:()=>c('font_family')||'Plus Jakarta Sans',set:v=>{config.font_family=v;window.elementSdk.setConfig({font_family:v});document.body.style.fontFamily=`${v}, Plus Jakarta Sans, sans-serif`}},
      fontSizeable:{get:()=>c('font_size')||14,set:v=>{config.font_size=v;window.elementSdk.setConfig({font_size:v})}}
    };
  },
  mapToEditPanelValues:(config)=>{
    const c=k=>config[k]||defaultConfig[k];
    return new Map([['company_name',c('company_name')],['system_title',c('system_title')]]);
  }
});

// ========== DATA SDK INIT ==========
const dataHandler = {
  onDataChanged(data) {
    allRecords = data;
    if(currentUser && currentView) renderCurrentView();
  }
};
(async()=>{
  const r = await window.dataSdk.init(dataHandler);
  if(!r.isOk) console.error('Data SDK init failed');
})();

// ========== UTILITIES ==========
function showToast(msg,type='success'){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.className=`toast toast-${type} show`;
  setTimeout(()=>t.classList.remove('show'),3000);
}
function getEmp(id){return EMPLOYEES.find(e=>e.id===id)}
function getEmpRecords(empId){return allRecords.filter(r=>r.employee_id===empId)}
function formatDate(d){if(!d)return'-';try{return new Date(d).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'})}catch(e){return d}}
function openModal(html){const o=document.getElementById('modalOverlay'),c=document.getElementById('modalContent');c.innerHTML=html;o.classList.add('show')}
function closeModal(){document.getElementById('modalOverlay').classList.remove('show')}

function switchLoginTab(mode){
  loginMode=mode;
  document.getElementById('loginTabEmployee').className=`tab-btn ${mode==='employee'?'active':''}`;
  document.getElementById('loginTabAdmin').className=`tab-btn ${mode==='admin'?'active':''}`;
  const hint=document.getElementById('loginHint');
  hint.textContent=mode==='employee'?'Karyawan: nama depan kecil / pass: infomedia123':'Admin: admin / pass: admin123';
  document.getElementById('loginError').style.display='none';
}

function handleLogin(){
  const u=document.getElementById('loginUser').value.trim().toLowerCase();
  const p=document.getElementById('loginPass').value;
  const err=document.getElementById('loginError');
  if(!u||!p){err.textContent='Username dan password harus diisi';err.style.display='block';return}
  const user=USERS[u];
  if(!user||user.pass!==p){err.textContent='Username atau password salah';err.style.display='block';return}
  if(loginMode==='employee'&&user.type!=='employee'){err.textContent='Gunakan tab Admin untuk login admin';err.style.display='block';return}
  if(loginMode==='admin'&&user.type!=='admin'){err.textContent='Gunakan tab Karyawan untuk login karyawan';err.style.display='block';return}
  currentUser=user.type==='employee'?{...user,emp:getEmp(user.empId)}:{...user};
  document.getElementById('loginPage').style.display='none';
  document.getElementById('dashboard').style.display='block';
  currentView='dashboard';
  buildSidebar();
  renderCurrentView();
  // ========== ABSENCE MANAGEMENT ==========
function renderAbsenceManagement(el){
  const absences=allRecords.filter(r=>r.type==='absence').sort((a,b)=>new Date(b.absence_date)-new Date(a.absence_date));
  const pending=absences.filter(r=>r.absence_type==='Pending').length;
  const approved=absences.filter(r=>r.absence_type==='Approved').length;
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">👤 Absence Management</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📋','Total',absences.length,'pengajuan','#a78bfa')}
    ${statCard('⏳','Pending',pending,'menunggu','#fbbf24')}
    ${statCard('✅','Approved',approved,'disetujui','#10b981')}
  </div>
  <div style="display:grid;gap:12px">
  ${absences.length?absences.map(a=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${a.employee_id}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">📅 ${formatDate(a.absence_date)}</div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${a.absence_reason}</div>
      </div>
      <span class="badge ${a.absence_type==='Approved'?'status-done':'status-progress'}">${a.absence_type}</span>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada absence</p></div>'}
  </div></div>`;
}

// ========== COMPLAINTS & GRIEVANCE ==========
function renderComplaintsManagement(el){
  const complaints=allRecords.filter(r=>r.type==='complaint').sort((a,b)=>new Date(b.complaint_date)-new Date(a.complaint_date));
  const open=complaints.filter(r=>r.complaint_status==='Open').length;
  const resolved=complaints.filter(r=>r.complaint_status==='Resolved').length;
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">📢 Complaints & Grievance</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📋','Total',complaints.length,'keluhan','#ec4899')}
    ${statCard('🔴','Open',open,'terbuka','#ef4444')}
    ${statCard('✅','Resolved',resolved,'selesai','#10b981')}
  </div>
  <div style="display:grid;gap:12px">
  ${complaints.length?complaints.map(c=>`<div class="card" style="padding:16px;border-left:3px solid ${c.complaint_status==='Open'?'#ef4444':'#10b981'}">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${c.complaint_title}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">Dari: ${c.employee_id} • ${formatDate(c.complaint_date)}</div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${c.complaint_description}</div>
      </div>
      <span class="badge ${c.complaint_status==='Open'?'status-pending':'status-done'}">${c.complaint_status}</span>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada keluhan</p></div>'}
  </div></div>`;
}

// ========== EQUIPMENT MANAGEMENT ==========
function renderEquipmentManagement(el){
  const equipments=allRecords.filter(r=>r.type==='equipment').sort((a,b)=>new Date(b.equipment_assignment_date)-new Date(a.equipment_assignment_date));
  const assigned=equipments.filter(r=>r.equipment_status==='Assigned').length;
  const available=equipments.filter(r=>r.equipment_status==='Available').length;
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📦 Equipment Management</h1>
    <button class="btn-primary" onclick="openAddEquipmentModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Tambah Equipment</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📦','Total',equipments.length,'items','#a78bfa')}
    ${statCard('✅','Tersedia',available,'siap pakai','#10b981')}
    ${statCard('👤','Terpinjam',assigned,'kepada karyawan','#00d4ff')}
  </div>
  <div style="display:grid;gap:12px">
  ${equipments.length?equipments.map(e=>`<div class="card" style="padding:14px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">📦 ${e.equipment_name}</div>
        <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:2px">${formatDate(e.equipment_assignment_date)} • Penerima: ${e.employee_id||'Storage'}</div>
      </div>
      <span class="badge ${e.equipment_status==='Available'?'status-done':'status-progress'}">${e.equipment_status}</span>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada equipment</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddEquipmentModal(){
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📦 Tambah Equipment</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Nama Equipment</label><input id="equipName" class="input-field" placeholder="Contoh: Laptop Dell XPS"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Status</label><select id="equipStatus" class="input-field"><option value="Available">Available</option><option value="Assigned">Assigned</option></select></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Assign ke Karyawan (opsional)</label>
      <select id="equipEmp" class="input-field">
        <option value="">-- Pilih atau biarkan kosong untuk storage --</option>
        ${EMPLOYEES.map(e=>`<option value="${e.id}">${e.name}</option>`).join('')}
      </select></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveEquipBtn" onclick="saveEquipment()">Simpan</button>
    </div>
  `);
}

async function saveEquipment(){
  const name=document.getElementById('equipName').value.trim();
  if(!name){showToast('Nama equipment harus diisi','error');return}
  const btn=document.getElementById('saveEquipBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'equipment',
    employee_id:document.getElementById('equipEmp').value,
    equipment_name:name,
    equipment_status:document.getElementById('equipStatus').value,
    equipment_assignment_date:new Date().toISOString(),
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',attendance_status:'',check_in_time:'',check_out_time:'',attendance_date:'',reward_name:'',reward_points:0,reward_date:'',discipline_type:'',discipline_level:'',discipline_reason:'',warning_count:0,salary_month:'',salary_amount:0,bonus:0,deduction:0,payslip_status:'',meeting_title:'',meeting_date:'',meeting_time:'',meeting_location:'',meeting_notes:'',attendees:'',document_type:'',document_name:'',document_date:'',document_expiry:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',overtime_hours:0,overtime_date:'',overtime_reason:'',absence_date:'',absence_reason:'',absence_type:'',complaint_title:'',complaint_description:'',complaint_date:'',complaint_status:'',ticket_id:'',employee_fitness_score:0,assessment_date:'',wellness_activity:'',health_checkup_date:'',certification_name:'',certification_issuer:'',certification_date:'',certification_expiry:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Equipment berhasil ditambahkan');closeModal();}
  else{showToast('Gagal menambahkan equipment','error');btn.disabled=false;btn.textContent='Simpan';}
}

// ========== WELLNESS PROGRAM ==========
function renderWellnessProgram(el){
  const wellness=allRecords.filter(r=>r.type==='wellness').sort((a,b)=>new Date(b.assessment_date)-new Date(a.assessment_date));
  const avgScore=(wellness.reduce((s,w)=>s+(w.employee_fitness_score||0),0)/(wellness.length||1)).toFixed(1);
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">❤️ Wellness Program</h1>
    <button class="btn-primary" onclick="openAddWellnessModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Catat Aktivitas</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('❤️','Peserta',wellness.length,'karyawan','#ec4899')}
    ${statCard('⭐','Rata-rata',avgScore,'/10','#fbbf24')}
  </div>
  <div style="display:grid;gap:12px">
  ${EMPLOYEES.map(emp=>{
    const empWellness=wellness.filter(w=>w.employee_id===emp.id).sort((a,b)=>new Date(b.assessment_date)-new Date(a.assessment_date))[0];
    return`<div class="card" style="padding:14px">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
        <div style="flex:1;display:flex;align-items:center;gap:12px">
          <div class="avatar" style="width:40px;height:40px;font-size:14px;background:${emp.color};color:#fff">${emp.photo}</div>
          <div>
            <div style="font-size:13px;font-weight:700">${emp.name}</div>
            ${empWellness?`<div style="font-size:11px;color:rgba(226,232,240,0.4)">${empWellness.wellness_activity} • ${formatDate(empWellness.assessment_date)}</div>`:'<div style="font-size:11px;color:rgba(226,232,240,0.4)">Belum ada data</div>'}
          </div>
        </div>
        ${empWellness?`<div style="text-align:right"><div style="font-size:18px;font-weight:800;color:#ec4899">${empWellness.employee_fitness_score}</div><div style="font-size:10px;color:rgba(226,232,240,0.4)">/10</div></div>`:''}
      </div>
    </div>`;
  }).join('')}
  </div></div>`;
  lucide.createIcons();
}

function openAddWellnessModal(){
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">❤️ Catat Wellness Activity</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Karyawan</label>
      <select id="wellnessEmp" class="input-field">
        <option value="">-- Pilih Karyawan --</option>
        ${EMPLOYEES.map(e=>`<option value="${e.id}">${e.name}</option>`).join('')}
      </select></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Aktivitas</label><input id="wellnessActivity" class="input-field" placeholder="Contoh: Yoga, Olahraga, Meditasi"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Fitness Score (1-10)</label><input id="wellnessScore" class="input-field" type="number" min="1" max="10" placeholder="8"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal Assessment</label><input id="wellnessDate" class="input-field" type="date"></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveWellnessBtn" onclick="saveWellness()">Simpan</button>
    </div>
  `);
  document.getElementById('wellnessDate').value=new Date().toISOString().split('T')[0];
}

async function saveWellness(){
  const empId=document.getElementById('wellnessEmp').value;
  const activity=document.getElementById('wellnessActivity').value.trim();
  const score=parseInt(document.getElementById('wellnessScore').value);
  if(!empId||!activity||!score){showToast('Semua field harus diisi','error');return}
  const btn=document.getElementById('saveWellnessBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'wellness',
    employee_id:empId,
    employee_fitness_score:score,
    assessment_date:document.getElementById('wellnessDate').value,
    wellness_activity:activity,
    health_checkup_date:'',activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',attendance_status:'',check_in_time:'',check_out_time:'',attendance_date:'',reward_name:'',reward_points:0,reward_date:'',discipline_type:'',discipline_level:'',discipline_reason:'',warning_count:0,salary_month:'',salary_amount:0,bonus:0,deduction:0,payslip_status:'',meeting_title:'',meeting_date:'',meeting_time:'',meeting_location:'',meeting_notes:'',attendees:'',document_type:'',document_name:'',document_date:'',document_expiry:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',overtime_hours:0,overtime_date:'',overtime_reason:'',absence_date:'',absence_reason:'',absence_type:'',complaint_title:'',complaint_description:'',complaint_date:'',complaint_status:'',ticket_id:'',equipment_name:'',equipment_status:'',equipment_assignment_date:'',certification_name:'',certification_issuer:'',certification_date:'',certification_expiry:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Wellness activity berhasil dicatat');closeModal();}
  else{showToast('Gagal menyimpan','error');btn.disabled=false;btn.textContent='Simpan';}
}

// ========== CERTIFICATIONS & LICENSES ==========
function renderCertificationsManagement(el){
  const certs=allRecords.filter(r=>r.type==='certification').sort((a,b)=>new Date(b.certification_date)-new Date(a.certification_date));
  const active=certs.filter(r=>new Date(r.certification_expiry)>new Date()).length;
  const expired=certs.filter(r=>new Date(r.certification_expiry)<=new Date()).length;
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📜 Certifications & Licenses</h1>
    <button class="btn-primary" onclick="openAddCertModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Tambah Sertifikat</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📜','Total',certs.length,'sertifikat','#a78bfa')}
    ${statCard('✅','Aktif',active,'berlaku','#10b981')}
    ${statCard('⚠️','Expired',expired,'kadaluarsa','#ef4444')}
  </div>
  <div style="display:grid;gap:12px">
  ${certs.length?certs.map(c=>{
    const isExpired=new Date(c.certification_expiry)<new Date();
    return`<div class="card" style="padding:14px;border-left:3px solid ${isExpired?'#ef4444':'#10b981'}">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
        <div style="flex:1">
          <div style="font-size:14px;font-weight:700">📜 ${c.certification_name}</div>
          <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:2px">${c.employee_id} • Penerbit: ${c.certification_issuer}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.5);margin-top:4px">Diperoleh: ${formatDate(c.certification_date)} | Berlaku sampai: ${formatDate(c.certification_expiry)}</div>
        </div>
        <span class="badge" style="background:rgba(${isExpired?'239,68,68':'16,185,129'},0.15);color:${isExpired?'#ef4444':'#34d399'}">${isExpired?'Expired':'Active'}</span>
      </div>
    </div>`;
  }).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada sertifikat</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddCertModal(){
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📜 Tambah Sertifikat</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Karyawan</label>
      <select id="certEmp" class="input-field">
        <option value="">-- Pilih Karyawan --</option>
        ${EMPLOYEES.map(e=>`<option value="${e.id}">${e.name}</option>`).join('')}
      </select></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Nama Sertifikat</label><input id="certName" class="input-field" placeholder="Contoh: ISO 9001 Lead Auditor"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Penerbit</label><input id="certIssuer" class="input-field" placeholder="Organisasi/Institusi"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal Diperoleh</label><input id="certDate" class="input-field" type="date"></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal Kadaluarsa</label><input id="certExpiry" class="input-field" type="date"></div>
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveCertBtn" onclick="saveCert()">Simpan</button>
    </div>
  `);
  document.getElementById('certDate').value=new Date().toISOString().split('T')[0];
}

