    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',rating:0,admin_feedback:'',category:'',daily_summary:'',doc_type:'',doc_url:'',attendance_status:'',check_in_time:'',check_out_time:'',attendance_date:'',reward_name:'',reward_points:0,reward_date:'',discipline_type:'',discipline_level:'',discipline_reason:'',warning_count:0,salary_month:'',salary_amount:0,bonus:0,deduction:0,payslip_status:'',meeting_title:'',meeting_date:'',meeting_time:'',meeting_location:'',meeting_notes:'',attendees:'',document_type:'',document_name:'',document_date:'',document_expiry:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',goal_title:'',goal_description:'',goal_target:0,goal_progress:0,goal_deadline:'',goal_owner:'',goal_status:'',badge_name:'',badge_icon:'',badge_criteria:'',employee_badges:'',badge_date:'',overtime_hours:0,overtime_date:'',overtime_reason:'',absence_date:'',absence_reason:'',absence_type:'',complaint_title:'',complaint_description:'',complaint_date:'',complaint_status:'',ticket_id:'',equipment_name:'',equipment_status:'',equipment_assignment_date:'',employee_fitness_score:0,assessment_date:'',wellness_activity:'',health_checkup_date:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Sertifikat berhasil ditambahkan');closeModal();}
  else{showToast('Gagal menyimpan sertifikat','error');btn.disabled=false;btn.textContent='Simpan';}
}

lucide.createIcons();
}

function handleLogout(){
  currentUser=null;
  document.getElementById('dashboard').style.display='none';
  document.getElementById('loginPage').style.display='flex';
  document.getElementById('loginUser').value='';
  document.getElementById('loginPass').value='';
  document.getElementById('loginError').style.display='none';
  if(isMobileMenuOpen)toggleMobileMenu();
}

function toggleMobileMenu(){
  isMobileMenuOpen=!isMobileMenuOpen;
  document.getElementById('mobileMenu').style.display=isMobileMenuOpen?'block':'none';
  lucide.createIcons();
}

// ========== SIDEBAR ==========
function buildSidebar(){
  const isAdmin=currentUser.type==='admin';
  let items=[];
  if(isAdmin){
    items=[
      {id:'dashboard',icon:'layout-dashboard',label:'Dashboard'},
      {id:'employees',icon:'users',label:'Semua Karyawan'},
      {id:'analytics',icon:'bar-chart-3',label:'Riset & Analisis'},
      {id:'ratings',icon:'star',label:'Penilaian Kinerja'},
      {id:'goals',icon:'target',label:'OKR & Goals'},
      {id:'badges',icon:'award',label:'Badges & Achievements'},
      {id:'skills',icon:'zap',label:'Skill Management'},
      {id:'notes',icon:'notepad',label:'Team Notes'},
      {id:'projects',icon:'briefcase',label:'Project Management'},
      {id:'events',icon:'calendar',label:'Event & Attendance'},
      {id:'performance',icon:'trending-up',label:'Performance Review'},
      {id:'training',icon:'book-open',label:'Training & Development'},
      {id:'announcements',icon:'megaphone',label:'Announcements'},
      {id:'attendance-system',icon:'clock',label:'Attendance System'},
      {id:'rewards',icon:'gift',label:'Rewards & Incentives'},
      {id:'discipline',icon:'alert-circle',label:'Discipline Management'},
      {id:'payroll',icon:'credit-card',label:'Payroll & Salary'},
      {id:'meetings',icon:'video',label:'Meeting Management'},
      {id:'leave-management',icon:'calendar-x',label:'Manajemen Cuti'},
      {id:'overtime',icon:'clock',label:'Lembur'},
      {id:'absence',icon:'user-x',label:'Absence Management'},
      {id:'complaints',icon:'alert-octagon',label:'Complaints & Grievance'},
      {id:'equipment',icon:'package',label:'Equipment Management'},
      {id:'wellness',icon:'heart',label:'Wellness Program'},
      {id:'certifications',icon:'certificate',label:'Certifications & Licenses'}
    ];
  } else {
    items=[
      {id:'dashboard',icon:'layout-dashboard',label:'Dashboard'},
      {id:'profile',icon:'user',label:'Profil Saya'},
      {id:'activities',icon:'clipboard-list',label:'Aktivitas'},
      {id:'documentation',icon:'file-image',label:'Dokumentasi'},
      {id:'summary',icon:'file-text',label:'Ringkasan Harian'},
      {id:'my-goals',icon:'target',label:'Goal Saya'},
      {id:'my-badges',icon:'award',label:'Achievement Badge'},
      {id:'my-skills',icon:'zap',label:'Skill Saya'},
      {id:'my-notes',icon:'notepad',label:'Note'},
      {id:'my-leaves',icon:'calendar-x',label:'Pengajuan Cuti'},
      {id:'my-overtime',icon:'clock',label:'Pengajuan Lembur'}
    ];
  }
  const buildNav=(containerId)=>{
    const nav=document.getElementById(containerId);
    if(!nav)return;
    nav.innerHTML=items.map(i=>`<div class="sidebar-item ${currentView===i.id?'active':''}" onclick="navigateTo('${i.id}')"><i data-lucide="${i.icon}" style="width:18px;height:18px"></i>${i.label}</div>`).join('');
  };
  buildNav('sidebarNav');buildNav('mobileNav');
  if(currentUser.type==='employee'&&currentUser.emp){
    document.getElementById('mobileAvatar').textContent=currentUser.emp.photo;
  } else {
    document.getElementById('mobileAvatar').textContent='A';
  }
  lucide.createIcons();
}

function navigateTo(view,extra){
  currentView=view;
  window._viewExtra=extra;
  buildSidebar();
  renderCurrentView();
  if(isMobileMenuOpen)toggleMobileMenu();
}

function renderCurrentView(){
  const main=document.getElementById('mainContent');
  const isAdmin=currentUser.type==='admin';
  if(isAdmin){
    switch(currentView){
      case 'dashboard':renderAdminDashboard(main);break;
      case 'employees':renderEmployeeList(main);break;
      case 'employee-detail':renderEmployeeDetail(main,window._viewExtra);break;
      case 'analytics':renderAnalytics(main);break;
      case 'ratings':renderRatings(main);break;
      case 'goals':renderGoalsAdmin(main);break;
      case 'badges':renderBadgesAdmin(main);break;
      case 'skills':renderSkillsAdmin(main);break;
      case 'notes':renderNotesAdmin(main);break;
      case 'projects':renderProjectsAdmin(main);break;
      case 'events':renderEventsAdmin(main);break;
      case 'performance':renderPerformanceAdmin(main);break;
      case 'training':renderTrainingAdmin(main);break;
      case 'announcements':renderAnnouncementsAdmin(main);break;
      case 'attendance-system':renderAttendanceSystem(main);break;
      case 'rewards':renderRewardsAdmin(main);break;
      case 'discipline':renderDisciplineAdmin(main);break;
      case 'payroll':renderPayrollAdmin(main);break;
      case 'meetings':renderMeetingsAdmin(main);break;
      case 'leave-management':renderLeaveManagement(main);break;
      case 'overtime':renderOvertimeManagement(main);break;
      case 'absence':renderAbsenceManagement(main);break;
      case 'complaints':renderComplaintsManagement(main);break;
      case 'equipment':renderEquipmentManagement(main);break;
      case 'wellness':renderWellnessProgram(main);break;
      case 'certifications':renderCertificationsManagement(main);break;
      default:renderAdminDashboard(main);
    }
  } else {
    switch(currentView){
      case 'dashboard':renderEmpDashboard(main);break;
      case 'profile':renderProfile(main);break;
      case 'activities':renderActivities(main);break;
      case 'documentation':renderDocumentation(main);break;
      case 'summary':renderSummary(main);break;
      case 'my-goals':renderMyGoals(main);break;
      case 'my-badges':renderMyBadges(main);break;
      case 'my-skills':renderMySkills(main);break;
      case 'my-notes':renderMyNotes(main);break;
      case 'my-leaves':renderMyLeaves(main);break;
      case 'my-overtime':renderMyOvertime(main);break;
      default:renderEmpDashboard(main);
    }
  }
  lucide.createIcons();
}

// ========== LEAVE & OVERTIME MANAGEMENT ==========
function renderLeaveManagement(el){
  const leaves=allRecords.filter(r=>r.type==='leave').sort((a,b)=>new Date(b.leave_start)-new Date(a.leave_start));
  const pending=leaves.filter(r=>r.leave_status==='Pending').length;
  const approved=leaves.filter(r=>r.leave_status==='Approved').length;
  const rejected=leaves.filter(r=>r.leave_status==='Rejected').length;
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">📋 Manajemen Cuti</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('⏳','Pending',pending,'permintaan','#fbbf24')}
    ${statCard('✅','Disetujui',approved,'cuti','#10b981')}
    ${statCard('❌','Ditolak',rejected,'permintaan','#ef4444')}
  </div>
  <div style="display:grid;gap:12px">
  ${leaves.length?leaves.map(l=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${l.employee_id}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">${l.leave_type} • ${formatDate(l.leave_start)} s/d ${formatDate(l.leave_end)}</div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${l.leave_reason}</div>
      </div>
      <div style="text-align:right">
        <span class="badge ${l.leave_status==='Approved'?'status-done':l.leave_status==='Rejected'?'status-pending':'status-progress'}">${l.leave_status}</span>
        <div style="margin-top:8px;display:flex;gap:4px">
          ${l.leave_status==='Pending'?`<button class="btn-secondary" style="font-size:10px;padding:3px 8px;color:#10b981;border-color:rgba(16,185,129,0.3)" onclick="approveLeave('${l.__backendId}')">✓ Setujui</button>
          <button class="btn-secondary" style="font-size:10px;padding:3px 8px;color:#ef4444;border-color:rgba(239,68,68,0.3)" onclick="rejectLeave('${l.__backendId}')">✕ Tolak</button>`:''}
        </div>
      </div>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada pengajuan cuti</p></div>'}
  </div></div>`;
}

async function approveLeave(backendId){
  const rec=allRecords.find(r=>r.__backendId===backendId);
  if(!rec)return;
  const result=await window.dataSdk.update({...rec,leave_status:'Approved',leave_approval_date:new Date().toISOString()});
  if(result.isOk)showToast('Cuti berhasil disetujui');
  else showToast('Gagal menyetujui cuti','error');
}

async function rejectLeave(backendId){
  const rec=allRecords.find(r=>r.__backendId===backendId);
  if(!rec)return;
  const result=await window.dataSdk.update({...rec,leave_status:'Rejected',leave_approval_date:new Date().toISOString()});
  if(result.isOk)showToast('Cuti berhasil ditolak');
  else showToast('Gagal menolak cuti','error');
}

function renderOvertimeManagement(el){
  const overtimes=allRecords.filter(r=>r.type==='overtime').sort((a,b)=>new Date(b.overtime_date)-new Date(a.overtime_date));
  const totalHours=overtimes.filter(r=>r.overtime_hours>0).reduce((s,r)=>s+(r.overtime_hours||0),0);
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">⏰ Manajemen Lembur</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📊','Total Lembur',totalHours.toFixed(1),'jam','#a78bfa')}
    ${statCard('📝','Pengajuan',overtimes.length,'kali','#ec4899')}
  </div>
  <div style="display:grid;gap:12px">
  ${overtimes.length?overtimes.map(o=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${o.employee_id}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">📅 ${formatDate(o.overtime_date)}</div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${o.overtime_reason}</div>
        <div style="font-size:13px;font-weight:600;color:#a78bfa;margin-top:6px">⏱ ${o.overtime_hours} jam</div>
      </div>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada pengajuan lembur</p></div>'}
  </div></div>`;
}

function renderMyLeaves(el){
  const emp=currentUser.emp;
  const leaves=getEmpRecords(emp.id).filter(r=>r.type==='leave').sort((a,b)=>new Date(b.leave_start)-new Date(a.leave_start));
  const approved=leaves.filter(r=>r.leave_status==='Approved').length;
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📋 Pengajuan Cuti</h1>
    <button class="btn-primary" onclick="openAddLeaveModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Ajukan Cuti</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:20px">
    ${statCard('📅','Total Cuti',approved,'hari','#10b981')}
  </div>
  <div style="display:grid;gap:12px">
  ${leaves.length?leaves.map(l=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">${l.leave_type}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">📅 ${formatDate(l.leave_start)} - ${formatDate(l.leave_end)}</div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${l.leave_reason}</div>
      </div>
      <div style="text-align:right">
        <span class="badge ${l.leave_status==='Approved'?'status-done':l.leave_status==='Rejected'?'status-pending':'status-progress'}">${l.leave_status}</span>
      </div>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada pengajuan cuti</p></div>'}
  </div></div>`;
}

function openAddLeaveModal(){
  if(allRecords.filter(r=>r.employee_id===currentUser.emp.id).length>=999){showToast('Batas data tercapai','error');return}
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📋 Ajukan Cuti</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Jenis Cuti</label><select id="leaveType" class="input-field"><option value="Cuti Tahunan">Cuti Tahunan</option><option value="Cuti Sakit">Cuti Sakit</option><option value="Cuti Khusus">Cuti Khusus</option></select></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal Mulai</label><input id="leaveStart" class="input-field" type="date"></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal Selesai</label><input id="leaveEnd" class="input-field" type="date"></div>
      </div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Alasan</label><textarea id="leaveReason" class="input-field" rows="3" placeholder="Tulis alasan cuti..."></textarea></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveLeaveBtn" onclick="saveLeave()">Ajukan</button>
    </div>
  `);
  document.getElementById('leaveStart').value=new Date().toISOString().split('T')[0];
  document.getElementById('leaveEnd').value=new Date().toISOString().split('T')[0];
}

async function saveLeave(){
  const reason=document.getElementById('leaveReason').value.trim();
  if(!reason){showToast('Alasan harus diisi','error');return}
  const btn=document.getElementById('saveLeaveBtn');btn.disabled=true;btn.textContent='Mengajukan...';
  const result=await window.dataSdk.create({
    type:'leave',
    employee_id:currentUser.emp.id,
    leave_type:document.getElementById('leaveType').value,
    leave_start:document.getElementById('leaveStart').value,
    leave_end:document.getElementById('leaveEnd').value,
    leave_reason:reason,
    leave_status:'Pending',
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',category:'',rating:0,admin_feedback:'',daily_summary:'',doc_type:'',doc_url:'',leave_approval_date:'',overtime_hours:0,overtime_date:'',overtime_reason:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Cuti berhasil diajukan');closeModal();}
  else{showToast('Gagal mengajukan cuti','error');btn.disabled=false;btn.textContent='Ajukan';}
}

function renderMyOvertime(el){
  const emp=currentUser.emp;
  const overtimes=getEmpRecords(emp.id).filter(r=>r.type==='overtime').sort((a,b)=>new Date(b.overtime_date)-new Date(a.overtime_date));
  const totalHours=overtimes.filter(r=>r.overtime_hours>0).reduce((s,r)=>s+(r.overtime_hours||0),0);
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">⏰ Pengajuan Lembur</h1>
    <button class="btn-primary" onclick="openAddOvertimeModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Ajukan Lembur</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:20px">
    ${statCard('⏱','Total Jam',totalHours.toFixed(1),'jam','#a78bfa')}
  </div>
  <div style="display:grid;gap:12px">
  ${overtimes.length?overtimes.map(o=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:700">📅 ${formatDate(o.overtime_date)}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">Durasi: <b>${o.overtime_hours} jam</b></div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:4px">${o.overtime_reason}</div>
      </div>
      <div style="text-align:right">
        <div style="font-size:14px;font-weight:700;color:#a78bfa">⏱ ${o.overtime_hours}h</div>
      </div>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:30px"><p style="color:rgba(226,232,240,0.3)">Belum ada pengajuan lembur</p></div>'}
  </div></div>`;
}

function openAddOvertimeModal(){
  if(allRecords.filter(r=>r.employee_id===currentUser.emp.id).length>=999){showToast('Batas data tercapai','error');return}
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">⏰ Ajukan Lembur</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal Lembur</label><input id="overtimeDate" class="input-field" type="date"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Durasi Lembur (jam)</label><input id="overtimeHours" class="input-field" type="number" min="1" max="12" placeholder="Contoh: 2"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Alasan Lembur</label><textarea id="overtimeReason" class="input-field" rows="3" placeholder="Tulis alasan lembur..."></textarea></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveOvertimeBtn" onclick="saveOvertime()">Ajukan</button>
    </div>
  `);
  document.getElementById('overtimeDate').value=new Date().toISOString().split('T')[0];
}

async function saveOvertime(){
  const hours=parseFloat(document.getElementById('overtimeHours').value);
  const reason=document.getElementById('overtimeReason').value.trim();
  if(!hours||hours<=0){showToast('Durasi harus valid','error');return}
  if(!reason){showToast('Alasan harus diisi','error');return}
  const btn=document.getElementById('saveOvertimeBtn');btn.disabled=true;btn.textContent='Mengajukan...';
  const result=await window.dataSdk.create({
    type:'overtime',
    employee_id:currentUser.emp.id,
    overtime_date:document.getElementById('overtimeDate').value,
    overtime_hours:hours,
    overtime_reason:reason,
    activity_title:'',activity_desc:'',activity_date:'',activity_status:'',category:'',rating:0,admin_feedback:'',daily_summary:'',doc_type:'',doc_url:'',leave_type:'',leave_reason:'',leave_status:'',leave_start:'',leave_end:'',leave_approval_date:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Lembur berhasil diajukan');closeModal();}
  else{showToast('Gagal mengajukan lembur','error');btn.disabled=false;btn.textContent='Ajukan';}
}

// ========== ADMIN VIEWS ==========
function renderAdminDashboard(el){
  const totalAct=allRecords.filter(r=>r.type==='activity').length;
  const totalDone=allRecords.filter(r=>r.type==='activity'&&r.activity_status==='Selesai').length;
  const totalDocs=allRecords.filter(r=>r.type==='documentation').length;
  const avgRating=allRecords.filter(r=>r.type==='activity'&&r.rating>0);
  const avg=avgRating.length?((avgRating.reduce((s,r)=>s+r.rating,0)/avgRating.length).toFixed(1)):'-';
  el.innerHTML=`
  <div class="animate-in" style="margin-bottom:24px">
    <h1 style="font-size:24px;font-weight:800;margin-bottom:4px">Selamat Datang, <span style="color:var(--accent)">${currentUser.name||'Admin'}</span></h1>
    <p style="color:rgba(226,232,240,0.5);font-size:14px">Panel Monitoring Karyawan PT. Infomedia Solusi Humanika</p>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:28px">
    ${statCard('👥','Total Karyawan','5','orang','#00d4ff')}
    ${statCard('📋','Total Aktivitas',totalAct,'kegiatan','#7c3aed')}
    ${statCard('✅','Selesai',totalDone,'aktivitas','#10b981')}
    ${statCard('⭐','Rata-rata Rating',avg,'/5','#fbbf24')}
    ${statCard('📁','Dokumentasi',totalDocs,'file','#ec4899')}
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px">
    <div class="card">
      <h3 style="font-size:16px;font-weight:700;margin-bottom:16px"><i data-lucide="users" style="width:18px;height:18px;display:inline;vertical-align:middle;color:var(--accent)"></i> Karyawan</h3>
      ${EMPLOYEES.map(e=>{
        const recs=getEmpRecords(e.id).filter(r=>r.type==='activity');
        const done=recs.filter(r=>r.activity_status==='Selesai').length;
        return`<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.05);cursor:pointer" onclick="navigateTo('employee-detail','${e.id}')">
          <div class="avatar" style="background:${e.color};color:#fff">${e.photo}</div>
          <div style="flex:1;min-width:0"><div style="font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${e.name}</div><div style="font-size:11px;color:rgba(226,232,240,0.4)">${e.dept} • ${e.role}</div></div>
          <div style="text-align:right"><span class="badge badge-${e.dept.toLowerCase()}">${e.dept}</span><div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:4px">${done}/${recs.length} selesai</div></div>
        </div>`;
      }).join('')}
    </div>
    <div class="card">
      <h3 style="font-size:16px;font-weight:700;margin-bottom:16px"><i data-lucide="activity" style="width:18px;height:18px;display:inline;vertical-align:middle;color:var(--accent)"></i> Aktivitas Terbaru</h3>
      ${allRecords.filter(r=>r.type==='activity').sort((a,b)=>new Date(b.created_at)-new Date(a.created_at)).slice(0,8).map(r=>{
        const emp=getEmp(r.employee_id);
        return`<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.03)">
          <div class="avatar" style="width:32px;height:32px;font-size:11px;background:${emp?emp.color:'#555'};color:#fff">${emp?emp.photo:'?'}</div>
          <div style="flex:1;min-width:0"><div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${r.activity_title||'-'}</div><div style="font-size:11px;color:rgba(226,232,240,0.4)">${emp?emp.name:'-'} • ${formatDate(r.activity_date)}</div></div>
          <span class="badge status-${r.activity_status==='Selesai'?'done':r.activity_status==='Proses'?'progress':'pending'}">${r.activity_status||'Pending'}</span>
        </div>`;
      }).join('')||'<p style="color:rgba(226,232,240,0.3);font-size:13px;text-align:center;padding:20px">Belum ada aktivitas tercatat</p>'}
    </div>
  </div>`;
}

function statCard(icon,label,value,unit,color){
  return`<div class="card animate-in" style="border-left:3px solid ${color}">
    <div style="font-size:24px;margin-bottom:4px">${icon}</div>
    <div style="font-size:24px;font-weight:800;color:${color}">${value} <span style="font-size:12px;font-weight:400;color:rgba(226,232,240,0.4)">${unit}</span></div>
    <div style="font-size:12px;color:rgba(226,232,240,0.5);margin-top:2px">${label}</div>
  </div>`;
}

function renderEmployeeList(el){
  el.innerHTML=`<div class="animate-in"><h1 style="font-size:22px;font-weight:800;margin-bottom:20px">Semua Karyawan</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px">
  ${EMPLOYEES.map(e=>{
    const recs=getEmpRecords(e.id).filter(r=>r.type==='activity');
    const done=recs.filter(r=>r.activity_status==='Selesai').length;
    const pct=recs.length?(done/recs.length*100).toFixed(0):0;
    const rated=recs.filter(r=>r.rating>0);
    const avgR=rated.length?(rated.reduce((s,r)=>s+r.rating,0)/rated.length).toFixed(1):'-';
    return`<div class="card" style="cursor:pointer" onclick="navigateTo('employee-detail','${e.id}')">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
        <div class="avatar" style="width:52px;height:52px;font-size:18px;background:${e.color};color:#fff">${e.photo}</div>
        <div><div style="font-size:16px;font-weight:700">${e.name}</div><span class="badge badge-${e.dept.toLowerCase()}" style="margin-top:4px">${e.dept} • ${e.role}</span></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:12px;margin-bottom:12px">
        <div><span style="color:rgba(226,232,240,0.4)">Aktivitas:</span> <b>${recs.length}</b></div>
        <div><span style="color:rgba(226,232,240,0.4)">Selesai:</span> <b style="color:#34d399">${done}</b></div>
        <div><span style="color:rgba(226,232,240,0.4)">Rating:</span> <b style="color:#fbbf24">${avgR}</b></div>
        <div><span style="color:rgba(226,232,240,0.4)">Bergabung:</span> <b>${formatDate(e.joined)}</b></div>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
      <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:4px;text-align:right">${pct}% selesai</div>
    </div>`;
  }).join('')}
  </div></div>`;
}

function renderEmployeeDetail(el,empId){
  const emp=getEmp(empId);if(!emp){el.innerHTML='<p>Karyawan tidak ditemukan</p>';return}
  const recs=getEmpRecords(empId);
  const acts=recs.filter(r=>r.type==='activity').sort((a,b)=>new Date(b.created_at)-new Date(a.created_at));
  const docs=recs.filter(r=>r.type==='documentation');
  const sums=recs.filter(r=>r.type==='summary').sort((a,b)=>new Date(b.activity_date)-new Date(a.activity_date));
  el.innerHTML=`<div class="animate-in">
  <button class="btn-secondary" onclick="navigateTo('employees')" style="margin-bottom:16px"><i data-lucide="arrow-left" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Kembali</button>
  <div class="card" style="margin-bottom:20px">
    <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
      <div class="avatar" style="width:64px;height:64px;font-size:22px;background:${emp.color};color:#fff">${emp.photo}</div>
      <div style="flex:1;min-width:200px">
        <h2 style="font-size:20px;font-weight:800">${emp.name}</h2>
        <span class="badge badge-${emp.dept.toLowerCase()}">${emp.dept}</span>
        <span style="color:rgba(226,232,240,0.5);font-size:13px;margin-left:8px">${emp.role}</span>
        <div style="display:flex;gap:20px;margin-top:8px;font-size:12px;color:rgba(226,232,240,0.5);flex-wrap:wrap">
          <span>📧 ${emp.email}</span><span>📱 ${emp.phone}</span><span>📅 Bergabung: ${formatDate(emp.joined)}</span>
        </div>
      </div>
    </div>
  </div>
  <h3 style="font-size:16px;font-weight:700;margin-bottom:12px">📋 Aktivitas (${acts.length})</h3>
  <div style="display:grid;gap:12px;margin-bottom:24px" id="empActList">
  ${acts.length?acts.map(a=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div><div style="font-size:15px;font-weight:600">${a.activity_title||'-'}</div>
      <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">${a.category||'-'} • ${formatDate(a.activity_date)}</div>
      <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:6px">${a.activity_desc||''}</div></div>
      <div style="text-align:right">
        <span class="badge status-${a.activity_status==='Selesai'?'done':a.activity_status==='Proses'?'progress':'pending'}">${a.activity_status||'Pending'}</span>
        <div style="margin-top:8px">${renderStarsAdmin(a)}</div>
      </div>
    </div>
    ${a.admin_feedback?`<div style="margin-top:10px;padding:10px;background:rgba(124,58,237,0.1);border-radius:8px;border-left:3px solid #7c3aed;font-size:12px"><b>Feedback Admin:</b> ${a.admin_feedback}</div>`:''}
    <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn-secondary" style="font-size:11px;padding:4px 12px" onclick="openFeedbackModal('${a.__backendId}','${(a.activity_title||'').replace(/'/g,"\\'")}')">💬 Feedback</button>
    </div>
  </div>`).join(''):'<p style="color:rgba(226,232,240,0.3);font-size:13px">Belum ada aktivitas</p>'}
  </div>
  <h3 style="font-size:16px;font-weight:700;margin-bottom:12px">📁 Dokumentasi (${docs.length})</h3>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:24px">
  ${docs.length?docs.map(d=>`<div class="card" style="padding:14px;text-align:center">
    <div style="font-size:32px;margin-bottom:8px">${d.doc_type==='video'?'🎬':'📸'}</div>
    <div style="font-size:13px;font-weight:600">${d.activity_title||'Dokumen'}</div>
    <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:2px">${formatDate(d.activity_date)}</div>
    ${d.doc_url?`<a href="${d.doc_url}" target="_blank" rel="noopener noreferrer" class="btn-secondary" style="display:inline-block;margin-top:8px;font-size:11px;padding:4px 12px;text-decoration:none">Buka Link</a>`:''}
  </div>`).join(''):'<p style="color:rgba(226,232,240,0.3);font-size:13px">Belum ada dokumentasi</p>'}
  </div>
  <h3 style="font-size:16px;font-weight:700;margin-bottom:12px">📝 Ringkasan Harian (${sums.length})</h3>
  ${sums.length?sums.map(s=>`<div class="card" style="padding:14px;margin-bottom:10px">
    <div style="display:flex;justify-content:space-between;font-size:13px"><b>${formatDate(s.activity_date)}</b><span class="badge badge-${emp.dept.toLowerCase()}">${emp.dept}</span></div>
    <p style="font-size:13px;color:rgba(226,232,240,0.7);margin-top:6px">${s.daily_summary||'-'}</p>
  </div>`).join(''):'<p style="color:rgba(226,232,240,0.3);font-size:13px">Belum ada ringkasan</p>'}
  </div>`;
}

function renderStarsAdmin(record){
  const rating=record.rating||0;
  let html='';
  for(let i=1;i<=5;i++){
    html+=`<span class="star ${i<=rating?'active':''}" style="color:${i<=rating?'#fbbf24':'rgba(226,232,240,0.2)'};font-size:16px;cursor:pointer" onclick="rateActivity('${record.__backendId}',${i})">★</span>`;
  }
  return html;
}

async function rateActivity(backendId,rating){
  const rec=allRecords.find(r=>r.__backendId===backendId);
  if(!rec)return;
  const result=await window.dataSdk.update({...rec,rating});
  if(result.isOk)showToast(`Rating ${rating}/5 berhasil disimpan`);
  else showToast('Gagal menyimpan rating','error');
}

function openFeedbackModal(backendId,title){
  const rec=allRecords.find(r=>r.__backendId===backendId);
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:4px">💬 Feedback untuk</h3>
    <p style="font-size:14px;color:var(--accent);margin-bottom:16px">${title}</p>
    <textarea id="feedbackText" class="input-field" rows="4" placeholder="Tulis saran atau feedback...">${rec&&rec.admin_feedback?rec.admin_feedback:''}</textarea>
    <div style="display:flex;gap:8px;margin-top:16px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveFeedbackBtn" onclick="saveFeedback('${backendId}')">Simpan Feedback</button>
    </div>
  `);
}

async function saveFeedback(backendId){
  const text=document.getElementById('feedbackText').value.trim();
  const rec=allRecords.find(r=>r.__backendId===backendId);
  if(!rec)return;
  const btn=document.getElementById('saveFeedbackBtn');
  btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.update({...rec,admin_feedback:text});
  if(result.isOk){showToast('Feedback berhasil disimpan');closeModal();}
  else{showToast('Gagal menyimpan feedback','error');btn.disabled=false;btn.textContent='Simpan Feedback';}
}

function renderAnalytics(el){
  const depts={CMO:0,HR:0,AM:0};
  const statusCount={Selesai:0,Proses:0,Pending:0};
  allRecords.filter(r=>r.type==='activity').forEach(r=>{
    const emp=getEmp(r.employee_id);
    if(emp)depts[emp.dept]=(depts[emp.dept]||0)+1;
    statusCount[r.activity_status||'Pending']=(statusCount[r.activity_status||'Pending']||0)+1;
  });
  const maxDept=Math.max(...Object.values(depts),1);
  const maxStatus=Math.max(...Object.values(statusCount),1);
  const deptColors={CMO:'#00d4ff',HR:'#7c3aed',AM:'#10b981'};
  const statusColors={Selesai:'#10b981',Proses:'#fbbf24',Pending:'#ef4444'};

  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">📊 Riset & Analisis</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-bottom:24px">
    <div class="card">
      <h3 style="font-size:15px;font-weight:700;margin-bottom:20px">Jumlah Aktivitas per Bagian</h3>
      <div style="display:flex;align-items:flex-end;gap:24px;height:180px;padding-bottom:30px;position:relative">
        ${Object.entries(depts).map(([dept,count])=>`<div style="flex:1;display:flex;flex-direction:column;align-items:center;height:100%;justify-content:flex-end">
          <div style="font-size:18px;font-weight:800;color:${deptColors[dept]};margin-bottom:6px">${count}</div>
          <div class="chart-bar" style="width:100%;height:${count?count/maxDept*120:4}px;background:linear-gradient(to top,${deptColors[dept]}88,${deptColors[dept]});max-width:80px"></div>
          <div style="font-size:12px;font-weight:600;margin-top:8px;color:${deptColors[dept]}">${dept}</div>
        </div>`).join('')}
      </div>
    </div>
    <div class="card">
      <h3 style="font-size:15px;font-weight:700;margin-bottom:20px">Status Aktivitas</h3>
      <div style="display:flex;align-items:flex-end;gap:24px;height:180px;padding-bottom:30px;position:relative">
        ${Object.entries(statusCount).map(([s,c])=>`<div style="flex:1;display:flex;flex-direction:column;align-items:center;height:100%;justify-content:flex-end">
          <div style="font-size:18px;font-weight:800;color:${statusColors[s]};margin-bottom:6px">${c}</div>
          <div class="chart-bar" style="width:100%;height:${c?c/maxStatus*120:4}px;background:linear-gradient(to top,${statusColors[s]}88,${statusColors[s]});max-width:80px"></div>
          <div style="font-size:12px;font-weight:600;margin-top:8px;color:${statusColors[s]}">${s}</div>
        </div>`).join('')}
      </div>
    </div>
  </div>
  <div class="card">
    <h3 style="font-size:15px;font-weight:700;margin-bottom:16px">Detail Aktivitas per Karyawan</h3>
    <div style="overflow-x:auto">
    <table style="width:100%;border-collapse:collapse;font-size:13px">
      <thead><tr style="border-bottom:2px solid rgba(0,212,255,0.2)">
        <th style="text-align:left;padding:10px;color:var(--accent)">Karyawan</th>
        <th style="text-align:left;padding:10px;color:var(--accent)">Dept</th>
        <th style="text-align:center;padding:10px;color:var(--accent)">Total</th>
        <th style="text-align:center;padding:10px;color:var(--accent)">Selesai</th>
        <th style="text-align:center;padding:10px;color:var(--accent)">Proses</th>
        <th style="text-align:center;padding:10px;color:var(--accent)">Rating</th>
      </tr></thead>
      <tbody>${EMPLOYEES.map(e=>{
        const recs=getEmpRecords(e.id).filter(r=>r.type==='activity');
        const done=recs.filter(r=>r.activity_status==='Selesai').length;
        const prog=recs.filter(r=>r.activity_status==='Proses').length;
        const rated=recs.filter(r=>r.rating>0);
        const avg=rated.length?(rated.reduce((s,r)=>s+r.rating,0)/rated.length).toFixed(1):'-';
        return`<tr style="border-bottom:1px solid rgba(255,255,255,0.03)">
          <td style="padding:10px"><div style="display:flex;align-items:center;gap:8px"><div class="avatar" style="width:28px;height:28px;font-size:10px;background:${e.color};color:#fff">${e.photo}</div>${e.name}</div></td>
          <td style="padding:10px"><span class="badge badge-${e.dept.toLowerCase()}">${e.dept}</span></td>
          <td style="text-align:center;padding:10px;font-weight:700">${recs.length}</td>
          <td style="text-align:center;padding:10px;color:#34d399;font-weight:700">${done}</td>
          <td style="text-align:center;padding:10px;color:#fbbf24;font-weight:700">${prog}</td>
          <td style="text-align:center;padding:10px;color:#fbbf24;font-weight:700">${avg}</td>
        </tr>`;
      }).join('')}</tbody>
    </table>
    </div>
  </div>
  </div>`;
}

function renderRatings(el){
  const acts=allRecords.filter(r=>r.type==='activity').sort((a,b)=>(b.rating||0)-(a.rating||0));
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">⭐ Penilaian Kinerja</h1>
  <div style="display:grid;gap:12px">
  ${EMPLOYEES.map(e=>{
    const recs=getEmpRecords(e.id).filter(r=>r.type==='activity');
    const rated=recs.filter(r=>r.rating>0);
    const avg=rated.length?(rated.reduce((s,r)=>s+r.rating,0)/rated.length).toFixed(1):'-';
    const perf=avg!=='-'?(avg>=4?'Sangat Baik':avg>=3?'Baik':avg>=2?'Cukup':'Perlu Perbaikan'):'Belum Dinilai';
    const perfColor=avg!=='-'?(avg>=4?'#10b981':avg>=3?'#00d4ff':avg>=2?'#fbbf24':'#ef4444'):'rgba(226,232,240,0.3)';
    return`<div class="card" style="padding:16px">
      <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
        <div class="avatar" style="width:48px;height:48px;font-size:16px;background:${e.color};color:#fff">${e.photo}</div>
        <div style="flex:1;min-width:180px">
          <div style="font-size:15px;font-weight:700">${e.name}</div>
          <div style="font-size:12px;color:rgba(226,232,240,0.4)">${e.dept} • ${e.role}</div>
        </div>
        <div style="text-align:right">
          <div style="font-size:28px;font-weight:800;color:${perfColor}">${avg!=='-'?avg:'—'}</div>
          <div style="font-size:11px;font-weight:600;color:${perfColor}">${perf}</div>
          <div style="font-size:11px;color:rgba(226,232,240,0.3);margin-top:2px">${rated.length}/${recs.length} dinilai</div>
        </div>
      </div>
    </div>`;
  }).join('')}
  </div></div>`;
}

// ========== EMPLOYEE VIEWS ==========
function renderEmpDashboard(el){
  const emp=currentUser.emp;
  const recs=getEmpRecords(emp.id);
  const acts=recs.filter(r=>r.type==='activity');
  const done=acts.filter(r=>r.activity_status==='Selesai').length;
  const progress=acts.filter(r=>r.activity_status==='Proses').length;
  const pending=acts.filter(r=>r.activity_status==='Pending').length;
  const docs=recs.filter(r=>r.type==='documentation').length;
  const sums=recs.filter(r=>r.type==='summary').length;
  const rated=acts.filter(r=>r.rating>0);
  const avg=rated.length?(rated.reduce((s,r)=>s+r.rating,0)/rated.length).toFixed(1):'-';
  const totalRec=recs.length;
  const pct=acts.length?(done/acts.length*100).toFixed(0):0;
  el.innerHTML=`<div class="animate-in">
  <div style="margin-bottom:24px">
    <h1 style="font-size:22px;font-weight:800">Halo, <span style="color:${emp.color}">${emp.name.split(' ')[0]}</span> 👋</h1>
    <p style="color:rgba(226,232,240,0.5);font-size:13px">${emp.dept} • ${emp.role}</p>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:24px">
    ${statCard('📋','Aktivitas',acts.length,'total',emp.color)}
    ${statCard('✅','Selesai',done,'aktivitas','#10b981')}
    ${statCard('⏳','Proses',progress,'aktivitas','#fbbf24')}
    ${statCard('⏸','Pending',pending,'aktivitas','#ef4444')}
    ${statCard('📁','Dokumentasi',docs,'file','#ec4899')}
    ${statCard('📝','Ringkasan',sums,'hari','#a78bfa')}
    ${statCard('⭐','Rating',avg,'/5','#fbbf24')}
  </div>
  <div class="card" style="margin-bottom:20px;background:linear-gradient(135deg,rgba(0,212,255,0.1),rgba(124,58,237,0.1));border:1px solid rgba(0,212,255,0.2)">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
      <div><div style="font-size:13px;color:rgba(226,232,240,0.5)">Progres Aktivitas Keseluruhan</div><div style="font-size:24px;font-weight:800;color:${pct>=80?'#10b981':pct>=50?'#00d4ff':'#fbbf24'}">${pct}%</div></div>
      <div style="text-align:right;font-size:12px"><div style="color:rgba(226,232,240,0.4)">Total: ${totalRec} data</div><div style="color:var(--accent);font-weight:700;margin-top:4px">${done}/${acts.length} selesai</div></div>
    </div>
    <div class="progress-bar"><div class="progress-fill" style="width:${pct}%;background:linear-gradient(90deg,${pct>=80?'#10b981':pct>=50?'#00d4ff':'#fbbf24'},${pct>=80?'#34d399':pct>=50?'#7dd3fc':'#fcd34d'})"></div></div>
    <div style="display:flex;gap:16px;margin-top:12px;font-size:11px;flex-wrap:wrap">
      <div><span style="color:rgba(226,232,240,0.4)">Selesai:</span> <b style="color:#10b981">${done}</b></div>
      <div><span style="color:rgba(226,232,240,0.4)">Proses:</span> <b style="color:#fbbf24">${progress}</b></div>
      <div><span style="color:rgba(226,232,240,0.4)">Pending:</span> <b style="color:#ef4444">${pending}</b></div>
    </div>
  </div>
  <div class="card" style="margin-bottom:16px">
    <h3 style="font-size:15px;font-weight:700;margin-bottom:12px">Aktivitas Terakhir</h3>
    ${acts.sort((a,b)=>new Date(b.created_at)-new Date(a.created_at)).slice(0,5).map(a=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.03);flex-wrap:wrap;gap:6px">
      <div><div style="font-size:13px;font-weight:500">${a.activity_title||'-'}</div><div style="font-size:11px;color:rgba(226,232,240,0.4)">${formatDate(a.activity_date)}</div></div>
      <div style="display:flex;align-items:center;gap:8px">
        <span class="badge status-${a.activity_status==='Selesai'?'done':a.activity_status==='Proses'?'progress':'pending'}">${a.activity_status||'Pending'}</span>
        ${a.rating?`<span style="color:#fbbf24;font-size:12px">${'★'.repeat(a.rating)}</span>`:''}
      </div>
    </div>`).join('')||'<p style="color:rgba(226,232,240,0.3);font-size:13px;text-align:center">Belum ada aktivitas. Tambahkan di menu Aktivitas.</p>'}
  </div>
  ${rated.length?`<div class="card"><h3 style="font-size:15px;font-weight:700;margin-bottom:8px">Feedback Terbaru</h3>
  ${rated.filter(r=>r.admin_feedback).slice(0,3).map(r=>`<div style="padding:8px;margin-top:8px;background:rgba(124,58,237,0.08);border-radius:8px;border-left:3px solid #7c3aed"><div style="font-size:12px;font-weight:600">${r.activity_title} <span style="color:#fbbf24">${'★'.repeat(r.rating)}</span></div><div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:4px">${r.admin_feedback}</div></div>`).join('')||'<p style="font-size:12px;color:rgba(226,232,240,0.3)">Belum ada feedback dari admin</p>'}
  </div>`:''}
  </div>`;
}

function renderProfile(el){
  const emp=currentUser.emp;
  const recs=getEmpRecords(emp.id).filter(r=>r.type==='activity');
  const done=recs.filter(r=>r.activity_status==='Selesai').length;
  const pct=recs.length?(done/recs.length*100).toFixed(0):0;
  el.innerHTML=`<div class="animate-in">
  <h1 style="font-size:22px;font-weight:800;margin-bottom:20px">Profil Saya</h1>
  <div class="card" style="max-width:600px">
    <div style="text-align:center;padding-bottom:20px;border-bottom:1px solid rgba(255,255,255,0.05);margin-bottom:20px">
      <div class="avatar" style="width:80px;height:80px;font-size:28px;background:${emp.color};color:#fff;margin:0 auto 12px">${emp.photo}</div>
      <h2 style="font-size:20px;font-weight:800">${emp.name}</h2>
      <span class="badge badge-${emp.dept.toLowerCase()}" style="margin-top:6px">${emp.dept} • ${emp.role}</span>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;font-size:13px">
      <div><span style="color:rgba(226,232,240,0.4);display:block;font-size:11px;margin-bottom:2px">Email</span><b>${emp.email}</b></div>
      <div><span style="color:rgba(226,232,240,0.4);display:block;font-size:11px;margin-bottom:2px">Telepon</span><b>${emp.phone}</b></div>
      <div><span style="color:rgba(226,232,240,0.4);display:block;font-size:11px;margin-bottom:2px">Tanggal Bergabung</span><b>${formatDate(emp.joined)}</b></div>
      <div><span style="color:rgba(226,232,240,0.4);display:block;font-size:11px;margin-bottom:2px">Departemen</span><b>${emp.dept}</b></div>
    </div>
    <div style="margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.05)">
      <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px"><span>Progres Aktivitas</span><span style="color:var(--accent);font-weight:700">${pct}%</span></div>
      <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
      <div style="font-size:11px;color:rgba(226,232,240,0.4);margin-top:4px">${done} dari ${recs.length} aktivitas selesai</div>
    </div>
  </div></div>`;
}

function renderActivities(el){
  const emp=currentUser.emp;
  const acts=getEmpRecords(emp.id).filter(r=>r.type==='activity').sort((a,b)=>new Date(b.created_at)-new Date(a.created_at));
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📋 Aktivitas Saya</h1>
    <button class="btn-primary" onclick="openAddActivityModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Tambah Aktivitas</button>
  </div>
  <div style="display:grid;gap:12px" id="actList">
  ${acts.length?acts.map(a=>`<div class="card" style="padding:16px" id="act-${a.__backendId}">
    <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:8px">
      <div style="flex:1;min-width:200px">
        <div style="font-size:15px;font-weight:600">${a.activity_title||'-'}</div>
        <div style="font-size:12px;color:rgba(226,232,240,0.4);margin-top:2px">${a.category||'-'} • ${formatDate(a.activity_date)}</div>
        <div style="font-size:13px;color:rgba(226,232,240,0.6);margin-top:6px">${a.activity_desc||''}</div>
      </div>
      <div style="text-align:right">
        <span class="badge status-${a.activity_status==='Selesai'?'done':a.activity_status==='Proses'?'progress':'pending'}">${a.activity_status||'Pending'}</span>
        ${a.rating?`<div style="color:#fbbf24;font-size:14px;margin-top:4px">${'★'.repeat(a.rating)}${'☆'.repeat(5-a.rating)}</div>`:''}
      </div>
    </div>
    ${a.admin_feedback?`<div style="margin-top:10px;padding:10px;background:rgba(124,58,237,0.08);border-radius:8px;border-left:3px solid #7c3aed;font-size:12px"><b>Feedback Admin:</b> ${a.admin_feedback}</div>`:''}
    <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
      <button class="btn-secondary" style="font-size:11px;padding:4px 12px" onclick="openEditActivityModal('${a.__backendId}')">✏️ Edit</button>
      <button class="btn-secondary" style="font-size:11px;padding:4px 12px;color:#ef4444;border-color:rgba(239,68,68,0.3)" onclick="confirmDelete('${a.__backendId}',this)">🗑 Hapus</button>
    </div>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:40px"><p style="color:rgba(226,232,240,0.3);font-size:14px">Belum ada aktivitas tercatat.<br>Klik tombol "Tambah Aktivitas" untuk memulai.</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddActivityModal(){
  if(getEmpRecords(currentUser.emp.id).length>=999){showToast('Batas maksimum 999 data tercapai','error');return;}
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">➕ Tambah Aktivitas Baru</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Judul Aktivitas</label><input id="actTitle" class="input-field" placeholder="Contoh: Meeting client"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Deskripsi</label><textarea id="actDesc" class="input-field" rows="3" placeholder="Deskripsi aktivitas..."></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal</label><input id="actDate" class="input-field" type="date"></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Status</label><select id="actStatus" class="input-field"><option value="Pending">Pending</option><option value="Proses">Proses</option><option value="Selesai">Selesai</option></select></div>
      </div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Kategori</label><select id="actCat" class="input-field"><option value="Meeting">Meeting</option><option value="Report">Report</option><option value="Project">Project</option><option value="Training">Training</option><option value="Lainnya">Lainnya</option></select></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveActBtn" onclick="saveActivity()">Simpan</button>
    </div>
  `);
  document.getElementById('actDate').value=new Date().toISOString().split('T')[0];
}

async function saveActivity(){
  const title=document.getElementById('actTitle').value.trim();
  if(!title){showToast('Judul aktivitas harus diisi','error');return}
  const btn=document.getElementById('saveActBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'activity',
    employee_id:currentUser.emp.id,
    activity_title:title,
    activity_desc:document.getElementById('actDesc').value.trim(),
    activity_date:document.getElementById('actDate').value,
    activity_status:document.getElementById('actStatus').value,
    category:document.getElementById('actCat').value,
    rating:0,admin_feedback:'',daily_summary:'',doc_type:'',doc_url:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Aktivitas berhasil ditambahkan');closeModal();}
  else{showToast('Gagal menyimpan aktivitas','error');btn.disabled=false;btn.textContent='Simpan';}
}

function openEditActivityModal(backendId){
  const rec=allRecords.find(r=>r.__backendId===backendId);if(!rec)return;
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">✏️ Edit Aktivitas</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Judul</label><input id="editTitle" class="input-field" value="${rec.activity_title||''}"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Deskripsi</label><textarea id="editDesc" class="input-field" rows="3">${rec.activity_desc||''}</textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal</label><input id="editDate" class="input-field" type="date" value="${rec.activity_date||''}"></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Status</label><select id="editStatus" class="input-field"><option value="Pending" ${rec.activity_status==='Pending'?'selected':''}>Pending</option><option value="Proses" ${rec.activity_status==='Proses'?'selected':''}>Proses</option><option value="Selesai" ${rec.activity_status==='Selesai'?'selected':''}>Selesai</option></select></div>
      </div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Kategori</label><select id="editCat" class="input-field"><option value="Meeting" ${rec.category==='Meeting'?'selected':''}>Meeting</option><option value="Report" ${rec.category==='Report'?'selected':''}>Report</option><option value="Project" ${rec.category==='Project'?'selected':''}>Project</option><option value="Training" ${rec.category==='Training'?'selected':''}>Training</option><option value="Lainnya" ${rec.category==='Lainnya'?'selected':''}>Lainnya</option></select></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="updateActBtn" onclick="updateActivity('${backendId}')">Update</button>
    </div>
  `);
}

async function updateActivity(backendId){
  const rec=allRecords.find(r=>r.__backendId===backendId);if(!rec)return;
  const btn=document.getElementById('updateActBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.update({...rec,
    activity_title:document.getElementById('editTitle').value.trim(),
    activity_desc:document.getElementById('editDesc').value.trim(),
    activity_date:document.getElementById('editDate').value,
    activity_status:document.getElementById('editStatus').value,
    category:document.getElementById('editCat').value
  });
  if(result.isOk){showToast('Aktivitas berhasil diupdate');closeModal();}
  else{showToast('Gagal mengupdate aktivitas','error');btn.disabled=false;btn.textContent='Update';}
}

async function confirmDelete(backendId,btnEl){
  const parent=btnEl.parentElement;
  if(parent.querySelector('.confirm-bar'))return;
  const bar=document.createElement('div');
  bar.className='confirm-bar';
  bar.innerHTML=`<span style="font-size:11px;color:#fca5a5">Yakin hapus?</span>
    <button class="btn-secondary" style="font-size:10px;padding:2px 10px;color:#ef4444;border-color:rgba(239,68,68,0.3)" onclick="doDelete('${backendId}',this)">Ya, Hapus</button>
    <button class="btn-secondary" style="font-size:10px;padding:2px 10px" onclick="this.closest('.confirm-bar').remove()">Batal</button>`;
  parent.appendChild(bar);
}

async function doDelete(backendId,btnEl){
  const rec=allRecords.find(r=>r.__backendId===backendId);if(!rec)return;
  btnEl.disabled=true;btnEl.textContent='Menghapus...';
  const result=await window.dataSdk.delete(rec);
  if(result.isOk)showToast('Data berhasil dihapus');
  else{showToast('Gagal menghapus data','error');btnEl.disabled=false;btnEl.textContent='Ya, Hapus';}
}

function renderDocumentation(el){
  const emp=currentUser.emp;
  const docs=getEmpRecords(emp.id).filter(r=>r.type==='documentation').sort((a,b)=>new Date(b.created_at)-new Date(a.created_at));
  const isMobile=/Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📁 Dokumentasi</h1>
    <button class="btn-primary" onclick="openAddDocModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Tambah Dokumen</button>
  </div>
  ${isMobile?`<div class="card" style="padding:12px;margin-bottom:16px;border-left:3px solid #fbbf24;background:rgba(251,191,36,0.05)">
    <div style="font-size:13px"><b>📱 Mode Mobile:</b> Untuk mengunggah foto, Anda akan diarahkan ke Google Drive. <a href="https://drive.google.com" target="_blank" rel="noopener noreferrer" style="color:var(--accent);text-decoration:underline">Buka Google Drive →</a></div>
  </div>`:''}
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px">
  ${docs.length?docs.map(d=>`<div class="card" style="padding:16px">
    <div style="text-align:center;margin-bottom:12px">
      <div style="width:64px;height:64px;margin:0 auto;border-radius:14px;background:${d.doc_type==='video'?'rgba(239,68,68,0.15)':'rgba(0,212,255,0.15)'};display:flex;align-items:center;justify-content:center;font-size:28px">${d.doc_type==='video'?'🎬':'📸'}</div>
    </div>
    <div style="font-size:14px;font-weight:600;text-align:center">${d.activity_title||'Dokumen'}</div>
    <div style="font-size:11px;color:rgba(226,232,240,0.4);text-align:center;margin-top:2px">${d.doc_type==='video'?'Video':'Foto'} • ${formatDate(d.activity_date)}</div>
    ${d.activity_desc?`<div style="font-size:12px;color:rgba(226,232,240,0.6);margin-top:8px;text-align:center">${d.activity_desc}</div>`:''}
    <div style="display:flex;gap:6px;margin-top:12px;justify-content:center">
      ${d.doc_url?`<a href="${d.doc_url}" target="_blank" rel="noopener noreferrer" class="btn-secondary" style="font-size:11px;padding:4px 12px;text-decoration:none">🔗 Buka</a>`:''}
      <button class="btn-secondary" style="font-size:11px;padding:4px 12px;color:#ef4444;border-color:rgba(239,68,68,0.3)" onclick="confirmDelete('${d.__backendId}',this)">🗑</button>
    </div>
  </div>`).join(''):'<div class="card" style="grid-column:1/-1;text-align:center;padding:40px"><p style="color:rgba(226,232,240,0.3)">Belum ada dokumentasi. Tambahkan foto atau video untuk mendokumentasikan hasil kerja.</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddDocModal(){
  if(allRecords.filter(r=>r.employee_id===currentUser.emp.id).length>=999){showToast('Batas data tercapai','error');return;}
  const isMobile=/Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📁 Tambah Dokumentasi</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Judul</label><input id="docTitle" class="input-field" placeholder="Judul dokumentasi"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Deskripsi</label><textarea id="docDesc" class="input-field" rows="2" placeholder="Deskripsi singkat"></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tipe</label><select id="docType" class="input-field"><option value="photo">📸 Foto</option><option value="video">🎬 Video</option></select></div>
        <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal</label><input id="docDate" class="input-field" type="date"></div>
      </div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Link ${isMobile?'Google Drive':'Dokumen'}</label><input id="docUrl" class="input-field" placeholder="${isMobile?'Paste link Google Drive':'Link ke foto/video (Google Drive, dll)'}"></div>
      ${isMobile?`<a href="https://drive.google.com" target="_blank" rel="noopener noreferrer" style="font-size:12px;color:var(--accent)">📱 Upload ke Google Drive dulu → lalu paste link di sini</a>`:'<p style="font-size:11px;color:rgba(226,232,240,0.4)">💻 Dari komputer: paste link langsung dari penyimpanan lokal atau cloud storage</p>'}
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveDocBtn" onclick="saveDoc()">Simpan</button>
    </div>
  `);
  document.getElementById('docDate').value=new Date().toISOString().split('T')[0];
}

async function saveDoc(){
  const title=document.getElementById('docTitle').value.trim();
  if(!title){showToast('Judul harus diisi','error');return}
  const btn=document.getElementById('saveDocBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'documentation',
    employee_id:currentUser.emp.id,
    activity_title:title,
    activity_desc:document.getElementById('docDesc').value.trim(),
    activity_date:document.getElementById('docDate').value,
    activity_status:'',category:'',rating:0,admin_feedback:'',daily_summary:'',
    doc_type:document.getElementById('docType').value,
    doc_url:document.getElementById('docUrl').value.trim(),
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Dokumentasi berhasil ditambahkan');closeModal();}
  else{showToast('Gagal menyimpan','error');btn.disabled=false;btn.textContent='Simpan';}
}

function renderSummary(el){
  const emp=currentUser.emp;
  const sums=getEmpRecords(emp.id).filter(r=>r.type==='summary').sort((a,b)=>new Date(b.activity_date)-new Date(a.activity_date));
  el.innerHTML=`<div class="animate-in">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 style="font-size:22px;font-weight:800">📝 Ringkasan Harian</h1>
    <button class="btn-primary" onclick="openAddSummaryModal()"><i data-lucide="plus" style="width:14px;height:14px;display:inline;vertical-align:middle"></i> Tulis Ringkasan</button>
  </div>
  <div style="display:grid;gap:12px">
  ${sums.length?sums.map(s=>`<div class="card" style="padding:16px">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px">
      <div style="font-size:14px;font-weight:700">📅 ${formatDate(s.activity_date)}</div>
      <div style="display:flex;gap:6px">
        <button class="btn-secondary" style="font-size:11px;padding:4px 10px" onclick="openEditSummaryModal('${s.__backendId}')">✏️</button>
        <button class="btn-secondary" style="font-size:11px;padding:4px 10px;color:#ef4444;border-color:rgba(239,68,68,0.3)" onclick="confirmDelete('${s.__backendId}',this)">🗑</button>
      </div>
    </div>
    <p style="font-size:13px;color:rgba(226,232,240,0.7);margin-top:8px;line-height:1.6;white-space:pre-wrap">${s.daily_summary||'-'}</p>
  </div>`).join(''):'<div class="card" style="text-align:center;padding:40px"><p style="color:rgba(226,232,240,0.3)">Belum ada ringkasan harian. Tulis ringkasan aktivitas harian Anda.</p></div>'}
  </div></div>`;
  lucide.createIcons();
}

function openAddSummaryModal(){
  if(allRecords.filter(r=>r.employee_id===currentUser.emp.id).length>=999){showToast('Batas data tercapai','error');return}
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📝 Ringkasan Harian Baru</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal</label><input id="sumDate" class="input-field" type="date"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Ringkasan</label><textarea id="sumText" class="input-field" rows="6" placeholder="Tulis ringkasan aktivitas hari ini..."></textarea></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="saveSumBtn" onclick="saveSummary()">Simpan</button>
    </div>
  `);
  document.getElementById('sumDate').value=new Date().toISOString().split('T')[0];
}

async function saveSummary(){
  const text=document.getElementById('sumText').value.trim();
  if(!text){showToast('Ringkasan harus diisi','error');return}
  const btn=document.getElementById('saveSumBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.create({
    type:'summary',
    employee_id:currentUser.emp.id,
    activity_title:'',activity_desc:'',
    activity_date:document.getElementById('sumDate').value,
    activity_status:'',category:'',rating:0,admin_feedback:'',
    daily_summary:text,doc_type:'',doc_url:'',
    created_at:new Date().toISOString()
  });
  if(result.isOk){showToast('Ringkasan berhasil disimpan');closeModal();}
  else{showToast('Gagal menyimpan','error');btn.disabled=false;btn.textContent='Simpan';}
}

function openEditSummaryModal(backendId){
  const rec=allRecords.find(r=>r.__backendId===backendId);if(!rec)return;
  openModal(`
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">✏️ Edit Ringkasan</h3>
    <div style="display:grid;gap:12px">
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Tanggal</label><input id="editSumDate" class="input-field" type="date" value="${rec.activity_date||''}"></div>
      <div><label style="font-size:12px;color:rgba(226,232,240,0.5)">Ringkasan</label><textarea id="editSumText" class="input-field" rows="6">${rec.daily_summary||''}</textarea></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:20px;justify-content:flex-end">
      <button class="btn-secondary" onclick="closeModal()">Batal</button>
      <button class="btn-primary" id="updateSumBtn" onclick="updateSummary('${backendId}')">Update</button>
    </div>
  `);
}

async function updateSummary(backendId){
  const rec=allRecords.find(r=>r.__backendId===backendId);if(!rec)return;
  const btn=document.getElementById('updateSumBtn');btn.disabled=true;btn.textContent='Menyimpan...';
  const result=await window.dataSdk.update({...rec,
    daily_summary:document.getElementById('editSumText').value.trim(),
    activity_date:document.getElementById('editSumDate').value
  });
